# ── Web3Forms (skjematjeneste) ────────────────────────────────
# Opprett gratis konto på https://web3forms.com og lim inn nøkkelen.
# Nøkkelen er OFFENTLIG og trygg i frontend — ok å committe til repo
# (men vi holder den i .env for enkel konfigurasjon).
PUBLIC_WEB3FORMS_KEY=din_web3forms_access_key_her

# ── GitHub Actions-secrets (legges IKKE her — kun i GitHub repo Settings) ──
# CALENDAR_ICS_URL = Outlook-kalenderens .ics-lenke for Umbukta-hytta
#   (hentes av update-availability.yml, aldri eksponert i frontend)
# WEB3FORMS_KEY    = Samme som PUBLIC_WEB3FORMS_KEY, brukes i build-steget

# ── Deploy-konfigurasjon (settes som GitHub Actions env-variabler) ──────────
# Uten eget domene (GitHub Pages):
#   SITE = https://t-event.github.io/fellesforbundet-helgeland-avd143
#   BASE = /fellesforbundet-helgeland-avd143
#
# Med eget domene (etter kjøp):
#   SITE = https://hytteutleie-ffh143.no
#   BASE = /
