---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  lang?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
  lang = 'no',
  noindex = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = siteUrl + Astro.url.pathname;
const ogImageUrl = siteUrl + base + ogImage;

// Brødsmule: «Forsiden / [side]» på undersider (fellesforbundet.no-mønster).
const sti = Astro.url.pathname.replace(base, '').replace(/^\/|\/$/g, '');
const sideNavn: Record<string, { no: string; en: string }> = {
  'bli-medlem':      { no: 'Bli medlem',          en: 'Join' },
  'lonn-tariff':     { no: 'Lønn & tariff',       en: 'Pay & agreements' },
  'tillitsvalgte':   { no: 'Tillitsvalgte',       en: 'Shop stewards' },
  'nyttige-lenker':  { no: 'Nyttige lenker',      en: 'Useful links' },
  'aktuelt':         { no: 'Aktuelt',             en: 'News' },
  'om-oss':          { no: 'Om oss',              en: 'About us' },
  'kontakt':         { no: 'Kontakt',             en: 'Contact' },
  'hytter':          { no: 'Hytteutleie',         en: 'Cabin rental' },
  'umbukta':         { no: 'Hytte i Umbukta',     en: 'Umbukta cabin' },
  'turtips':         { no: 'Turtips Umbukta',     en: 'Hiking tips (Umbukta)' },
  'hjelp':           { no: 'Hjelp – hytteutleie', en: 'Help – cabin rental' },
  'personvern':      { no: 'Personvern',          en: 'Privacy' },
  'cookies':         { no: 'Cookies',             en: 'Cookies' },
  'vilkar':          { no: 'Vilkår',              en: 'Terms' },
  'tilgjengelighet': { no: 'Tilgjengelighet',     en: 'Accessibility' },
  'takk':            { no: 'Takk',                en: 'Thank you' },
};
const brodsmule = sideNavn[sti];
// Sider som åpner med mørk hero (eller bildehero) → navy brødsmule m/hvit tekst,
// så den smelter sammen med seksjonen under. Øvrige sider er lyse (gjennomsiktig).
const morkeHero = new Set([
  'bli-medlem', 'lonn-tariff', 'tillitsvalgte', 'aktuelt',
  'om-oss', 'kontakt', 'hytter', 'turtips', 'umbukta',
]);
const brodsmuleMork = morkeHero.has(sti);
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#1A1836" />

  <!-- Content-Security-Policy. GitHub Pages kan ikke sette HTTP-headere, så
       policyen leveres via meta. 'unsafe-inline' er nødvendig fordi siden bruker
       inline style-attributter og define:vars-skript overalt. Eksterne hoster
       er begrenset til det siden faktisk bruker — oppdater ved nye integrasjoner:
       img-src (Statens vegvesen-webkamera + hCaptcha), frame-src (Google Maps +
       Facebook + hCaptcha), connect-src (Yr + Web3Forms + hCaptcha), script-src
       (Web3Forms-klient + hCaptcha). connect-src MÅ ha 'self' — kalender/booking
       henter availability.json fra eget domene, og connect-src overstyrer default-src.
       hCaptcha (spamvern på skjemaene) laster fra hcaptcha.com/*.hcaptcha.com, og
       widget-scriptet fra web3forms.com. NB: frame-ancestors/sandbox ignoreres i
       meta-CSP og settes ikke her. -->
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self' data: https://kamera.atlas.vegvesen.no https://*.hcaptcha.com; font-src 'self'; style-src 'self' 'unsafe-inline' https://hcaptcha.com https://*.hcaptcha.com; script-src 'self' 'unsafe-inline' https://web3forms.com https://hcaptcha.com https://*.hcaptcha.com; connect-src 'self' https://api.met.no https://api.web3forms.com https://hcaptcha.com https://*.hcaptcha.com; frame-src https://www.google.com https://maps.google.com https://www.facebook.com https://hcaptcha.com https://*.hcaptcha.com; form-action 'self' https://api.web3forms.com" />

  <!-- Tittel og meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type"        content={ogType} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:image"       content={ogImageUrl} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="nb_NO" />
  <meta property="og:site_name"   content="Fellesforbundet Helgeland — Hytteutleie" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageUrl} />

  <!-- Schema.org Organisation -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Fellesforbundet Helgeland avd. 143",
    "url": siteUrl + base,
    "logo": siteUrl + base + "/images/logo/ff_logo_hvit_rgb-01.png",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+47-75151228",
      "contactType": "customer service",
      "availableLanguage": ["Norwegian", "English"]
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Søndre gate 13",
      "addressLocality": "Mo i Rana",
      "postalCode": "8624",
      "addressCountry": "NO"
    }
  })} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
</head>
<body>
  <a class="skip-link" href="#main-content" data-en="Skip to content">Hopp til innhold</a>
  <Header />
  {brodsmule && (
    <nav class={`brodsmule${brodsmuleMork ? ' brodsmule--mork' : ''}`} aria-label="Du er her">
      <div class="container">
        <a href={`${base}/`} data-en="Home">Forsiden</a>
        <span class="brodsmule-sep" aria-hidden="true">/</span>
        <span class="brodsmule-na" data-en={brodsmule.en}>{brodsmule.no}</span>
      </div>
    </nav>
  )}
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <CookieConsent />

  <!-- Varsel før man forlater avdelingens nettside til en ekstern side -->
  <div class="ext-modal" id="ext-modal" role="dialog" aria-modal="true" aria-labelledby="ext-tittel" aria-describedby="ext-tekst">
    <div class="ext-modal-overlay" aria-hidden="true"></div>
    <div class="ext-modal-box">
      <div class="ext-modal-ic" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </div>
      <h2 id="ext-tittel" data-en="You are leaving our website">Du forlater avdelingens nettside</h2>
      <p id="ext-tekst" data-en="You are being sent to an external website that the branch does not control:">Du sendes nå til en ekstern nettside som avdelingen ikke har kontroll over:</p>
      <strong class="ext-host" id="ext-host"></strong>
      <div class="ext-actions">
        <button type="button" class="btn btn-primary" id="ext-go" data-en="Continue to the site">Fortsett til siden</button>
        <button type="button" class="btn btn-secondary" id="ext-cancel" data-en="Cancel">Avbryt</button>
      </div>
    </div>
  </div>

  <!-- Språkbytte-skript (initialiseres fra lagret localStorage-preferanse) -->
  <script>
    import { translations } from '../i18n/translations.ts';

    type Lang = 'nb' | 'en';

    // Cache for original (norsk) innhold, slik at vi kan bytte tilbake fra engelsk.
    const noHtml = new WeakMap<HTMLElement, string>();
    const noPh   = new WeakMap<HTMLInputElement | HTMLTextAreaElement, string>();

    function applyLang(lang: Lang) {
      const t = translations[lang];
      // 1) Delte strenger via translations.ts (nav, overskrifter, skjemaetiketter)
      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n') as keyof typeof t;
        if (key && key in t) el.textContent = t[key];
      });
      document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach(el => {
        const key = el.getAttribute('data-i18n-placeholder') as keyof typeof t;
        if (key && key in t && el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
          (el as HTMLInputElement).placeholder = t[key];
        }
      });
      // 2) Inline engelsk: data-en bytter innerHTML, data-en-ph bytter placeholder.
      //    Engelsk ligger ved siden av norsk i HTML-en; norsk caches ved første kjøring.
      document.querySelectorAll<HTMLElement>('[data-en]').forEach(el => {
        if (!noHtml.has(el)) noHtml.set(el, el.innerHTML);
        el.innerHTML = lang === 'en' ? (el.getAttribute('data-en') ?? '') : (noHtml.get(el) ?? '');
      });
      document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-en-ph]').forEach(el => {
        if (!noPh.has(el)) noPh.set(el, el.placeholder);
        el.placeholder = lang === 'en' ? (el.getAttribute('data-en-ph') ?? '') : (noPh.get(el) ?? '');
      });
      document.documentElement.lang = lang === 'nb' ? 'no' : 'en';
      document.querySelectorAll<HTMLElement>('.lang button').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
      });
      localStorage.setItem('lang', lang);
    }

    const saved = (localStorage.getItem('lang') as Lang) || 'nb';
    applyLang(saved);

    document.querySelectorAll<HTMLElement>('.lang button').forEach(btn => {
      btn.addEventListener('click', () => {
        applyLang((btn.dataset.lang as Lang) || 'nb');
      });
    });
  </script>

  <!-- FAQ-accordion (global) -->
  <script>
    document.querySelectorAll('.acc-head').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.closest('.acc-item')?.classList.toggle('open');
      });
    });
  </script>

  <!-- «Meny»-knapp → full meny (alle skjermstørrelser) -->
  <script>
    const toggle = document.getElementById('nav-toggle');
    const navMobile = document.getElementById('nav-mobile');
    const header = document.querySelector('.site-header');

    // Full-menyen starter rett under headeren — sett høyden dynamisk (topp-rad
    // + hovedrad varierer med skjermbredde).
    function settHeaderHoyde() {
      if (header) document.documentElement.style.setProperty('--header-h', header.offsetHeight + 'px');
    }
    settHeaderHoyde();
    window.addEventListener('resize', settHeaderHoyde);

    function lukkMeny() {
      navMobile?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
    toggle?.addEventListener('click', () => {
      settHeaderHoyde();
      const open = navMobile?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!!open));
    });
    navMobile?.querySelectorAll('a').forEach(a => a.addEventListener('click', lukkMeny));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') lukkMeny(); });
  </script>

  <!-- Ekstern-lenke-varsel: fang klikk på lenker til andre domener og bekreft først -->
  <script>
    (function () {
      const modal   = document.getElementById('ext-modal');
      const hostEl  = document.getElementById('ext-host');
      const goBtn   = document.getElementById('ext-go') as HTMLButtonElement | null;
      const cancel  = document.getElementById('ext-cancel');
      const overlay = modal?.querySelector('.ext-modal-overlay');
      let pending: { url: string; nyFane: boolean } | null = null;

      function erEkstern(a: HTMLAnchorElement): boolean {
        const href = a.getAttribute('href') || '';
        if (/^(mailto:|tel:|#|javascript:)/i.test(href)) return false;
        let u: URL;
        try { u = new URL(a.href, location.href); } catch { return false; }
        if (u.protocol !== 'http:' && u.protocol !== 'https:') return false;
        return u.hostname !== location.hostname;
      }

      function lukk() { modal?.classList.remove('open'); pending = null; }

      document.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        const a = t.closest?.('a[href]') as HTMLAnchorElement | null;
        if (!a || !erEkstern(a)) return;
        e.preventDefault();
        pending = { url: a.href, nyFane: a.target === '_blank' };
        if (hostEl) hostEl.textContent = new URL(a.href).hostname.replace(/^www\./, '');
        modal?.classList.add('open');
        goBtn?.focus();
      });

      goBtn?.addEventListener('click', () => {
        if (!pending) return;
        const { url, nyFane } = pending;
        lukk();
        if (nyFane) window.open(url, '_blank', 'noopener');
        else location.href = url;
      });
      cancel?.addEventListener('click', lukk);
      overlay?.addEventListener('click', lukk);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') lukk(); });
    })();
  </script>
</body>
</html>
