---
// Kalenderkomponent — viser ledig/opptatt/loddtrekning.
// Faktisk data og rendring skjer client-side via calendar.ts.
---

<div class="cal" id="cal" aria-label="Ledighetskalender for Umbukta">
  <div class="cal-head">
    <b id="cal-title" data-en="Loading calendar…">Laster kalender…</b>
    <div class="cal-nav">
      <button id="cal-prev" aria-label="Forrige måned">‹</button>
      <button id="cal-next" aria-label="Neste måned">›</button>
    </div>
  </div>
  <button type="button" id="cal-neste" class="cal-neste" style="display:none;"></button>
  <div class="cal-weekdays" aria-hidden="true">
    <span data-en="Mon">Man</span><span data-en="Tue">Tir</span><span data-en="Wed">Ons</span>
    <span data-en="Thu">Tor</span><span data-en="Fri">Fre</span><span data-en="Sat">Lør</span><span data-en="Sun">Søn</span>
  </div>
  <div class="cal-grid" id="cal-grid" role="grid" aria-label="Dager"></div>
  <div class="cal-legend" aria-label="Tegnforklaring">
    <span><span class="swatch" style="background:#fff; border:1px solid var(--kantlinje);"></span><span data-i18n="cal_ledig">Ledig</span></span>
    <span><span class="swatch" style="background:var(--rosa);"></span><span data-i18n="cal_opptatt">Opptatt</span></span>
    <span><span class="swatch" style="background:var(--rod);"></span><span data-i18n="cal_valgt">Valgt</span></span>
    <span><span class="swatch" style="background:var(--gul);"></span><span data-i18n="cal_lodd">Loddtrekning</span></span>
  </div>
  <p class="cal-note" data-i18n="cal_note">
    Gule dager = påske (loddtrekning). Kalender oppdateres ca. én gang i timen.
  </p>
  <p id="cal-lodd-melding" class="cal-lodd-melding" role="status" aria-live="polite" style="display:none;"></p>
</div>

<script>
import { getRelevantEaster, isEasterSectionVisible } from '../utils/easter.ts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Availability {
  lastUpdated: string;
  bookedDates: string[];
}

let availability: Availability = { lastUpdated: '', bookedDates: [] };
let easterDates: Set<string> = new Set();

// Datoer valgt av bruker (for booking-skjema)
let selectedFrom: string | null = null;
let selectedTo:   string | null = null;

// Vis inneværende måned ved oppstart
let viewYear  = new Date().getFullYear();
let viewMonth = new Date().getMonth(); // 0-indexed

const grid   = document.getElementById('cal-grid')!;
const title  = document.getElementById('cal-title')!;
const btnPrev = document.getElementById('cal-prev')!;
const btnNext = document.getElementById('cal-next')!;

const MÅNEDER = ['Januar','Februar','Mars','April','Mai','Juni',
                 'Juli','August','September','Oktober','November','Desember'];
const MONTHS_EN = ['January','February','March','April','May','June',
                   'July','August','September','October','November','December'];
const erEn = () => localStorage.getItem('lang') === 'en';

function isoDate(y: number, m: number, d: number): string {
  return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
}

function parseIso(s: string): Date {
  const [y,m,d] = s.split('-').map(Number);
  return new Date(y, m-1, d);
}

// Sjekker om nettene [fra, til) inneholder en opptatt dato (utsjekk-dagen er ledig).
function rangeHarOpptatt(fra: string, til: string): boolean {
  const d = parseIso(fra), end = parseIso(til);
  while (d < end) {
    if (availability.bookedDates.includes(isoDate(d.getFullYear(), d.getMonth(), d.getDate()))) return true;
    d.setDate(d.getDate() + 1);
  }
  return false;
}

function renderCalendar() {
  const today = new Date(); today.setHours(0,0,0,0);
  const firstDay = new Date(viewYear, viewMonth, 1);
  const lastDay  = new Date(viewYear, viewMonth + 1, 0);

  // Ukedag for 1. i måneden: mandag=0
  let startDow = firstDay.getDay(); // 0=søn..6=lør
  startDow = startDow === 0 ? 6 : startDow - 1; // Gjør man=0

  title.textContent = `${(erEn() ? MONTHS_EN : MÅNEDER)[viewMonth]} ${viewYear}`;

  let html = '';

  // Tomme celler for å justere første dag
  for (let i = 0; i < startDow; i++) {
    html += '<div class="day tom" aria-hidden="true"></div>';
  }

  for (let d = 1; d <= lastDay.getDate(); d++) {
    const iso = isoDate(viewYear, viewMonth, d);
    const date = parseIso(iso);
    const isToday = date.getTime() === today.getTime();
    const isPast  = date < today;

    let cls = 'day';
    let label = String(d);
    let role  = 'gridcell';
    let ariaLabel = `${d}. ${MÅNEDER[viewMonth]} ${viewYear}`;
    let clickable = false;
    let tabIndex = '-1';

    if (isPast) {
      cls += ' fortid';
      ariaLabel += ' (fortid)';
    } else if (easterDates.has(iso)) {
      cls += ' lodd';
      ariaLabel += ' (loddtrekning — påske)';
      clickable = true;
    } else if (availability.bookedDates.includes(iso)) {
      cls += ' opptatt';
      ariaLabel += ' (opptatt)';
    } else {
      // Ledig
      if (selectedFrom && selectedTo) {
        const f = parseIso(selectedFrom);
        const t = parseIso(selectedTo);
        if (iso === selectedFrom || iso === selectedTo) {
          cls += ' valgt';
        } else if (date > f && date < t) {
          cls += ' rekkevidde';
        } else {
          cls += ' ledig';
          clickable = true;
        }
      } else if (selectedFrom && !selectedTo) {
        if (iso === selectedFrom) {
          cls += ' valgt';
        } else if (date > parseIso(selectedFrom)) {
          cls += ' ledig';
          clickable = true;
        } else {
          cls += ' ledig';
          clickable = true;
        }
      } else {
        cls += ' ledig';
        clickable = true;
      }
      tabIndex = '0';
    }

    if (isToday) ariaLabel += ' (i dag)';

    html += `<div
      class="${cls}"
      role="${role}"
      data-date="${iso}"
      aria-label="${ariaLabel}"
      ${clickable ? `tabindex="${tabIndex}"` : ''}
    >${label}</div>`;
  }

  grid.innerHTML = html;

  // Klikkhåndtering
  grid.querySelectorAll<HTMLElement>('.day.ledig, .day.lodd').forEach(el => {
    el.addEventListener('click', () => handleDayClick(el.dataset.date!));
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        handleDayClick(el.dataset.date!);
      }
    });
  });
}

// Info-melding for gule (loddtrekning) dager når påmelding ikke er åpnet ennå.
let loddMeldingVist = false;
function visLoddMelding(now: Date) {
  const el = document.getElementById('cal-lodd-melding');
  if (!el) return;
  const ep = getRelevantEaster(now);
  const dato = ep.registrationStart.toLocaleDateString(erEn() ? 'en-GB' : 'nb-NO',
    { day: 'numeric', month: 'long', year: 'numeric' });
  el.textContent = erEn()
    ? `The Easter draw is not open yet. Registration for ${ep.year} opens ${dato}.`
    : `Loddtrekningen er ikke åpen ennå. Påmelding for ${ep.year} åpner ${dato}.`;
  el.style.display = '';
  loddMeldingVist = true;
}
function skjulLoddMelding() {
  const el = document.getElementById('cal-lodd-melding');
  if (el) el.style.display = 'none';
  loddMeldingVist = false;
}

function handleDayClick(iso: string) {
  if (easterDates.has(iso)) {
    const now = new Date();
    if (isEasterSectionVisible(now)) {
      // Loddtrekning-seksjonen er synlig (påmelding åpen, eller frist passert med
      // beskjed i seksjonen) — scroll dit.
      skjulLoddMelding();
      document.getElementById('paske-seksjon')?.scrollIntoView({ behavior: 'smooth' });
    } else {
      // Påmelding er ikke åpnet ennå (seksjonen er skjult) — fortell når den åpner,
      // så et klikk på en gul dag ikke bare scroller til et kollapset element.
      visLoddMelding(now);
    }
    return;
  }
  skjulLoddMelding();

  if (!selectedFrom || (selectedFrom && selectedTo)) {
    // Start ny valg
    selectedFrom = iso;
    selectedTo   = null;
  } else {
    // Andre klikk = til-dato. Hvis perioden ville spenne over opptatte netter,
    // start i stedet et nytt valg fra denne dagen.
    if (iso <= selectedFrom || rangeHarOpptatt(selectedFrom, iso)) {
      selectedFrom = iso;
      selectedTo   = null;
    } else {
      selectedTo = iso;
    }
  }
  renderCalendar();
  updateBookingForm();
}

function updateBookingForm() {
  const fromInput = document.getElementById('booking-fra') as HTMLInputElement | null;
  const toInput   = document.getElementById('booking-til') as HTMLInputElement | null;
  if (fromInput && selectedFrom) fromInput.value = selectedFrom;
  if (toInput   && selectedTo)   toInput.value   = selectedTo;
  // Utløs change-event for prisberegning
  fromInput?.dispatchEvent(new Event('change'));
  toInput?.dispatchEvent(new Event('change'));
}

// Eksporter valgte datoer for bruk av BookingForm
(window as typeof window & { getCalSelection: () => {from:string|null; to:string|null} })
  .getCalSelection = () => ({ from: selectedFrom, to: selectedTo });

// «Neste ledige»-hint: første dato fra i dag som verken er opptatt eller påske.
function fmtDato(iso: string): string {
  return parseIso(iso).toLocaleDateString(erEn() ? 'en-GB' : 'nb-NO', { weekday: 'short', day: 'numeric', month: 'long' });
}
function finnNesteLedige(): string | null {
  const d = new Date(); d.setHours(0,0,0,0);
  for (let i = 0; i < 400; i++) {
    const iso = isoDate(d.getFullYear(), d.getMonth(), d.getDate());
    if (!availability.bookedDates.includes(iso) && !easterDates.has(iso)) return iso;
    d.setDate(d.getDate() + 1);
  }
  return null;
}
function oppdaterNesteLedige() {
  const el = document.getElementById('cal-neste');
  if (!el) return;
  const iso = finnNesteLedige();
  if (!iso) { el.style.display = 'none'; return; }
  const today = new Date();
  const todayIso = isoDate(today.getFullYear(), today.getMonth(), today.getDate());
  el.style.display = '';
  el.dataset.date = iso;
  el.innerHTML = iso === todayIso
    ? (erEn() ? 'Available from today →' : 'Ledig fra i dag →')
    : (erEn() ? `Next available: <b>${fmtDato(iso)}</b> →` : `Neste ledige: <b>${fmtDato(iso)}</b> →`);
}
document.getElementById('cal-neste')?.addEventListener('click', (e) => {
  const iso = (e.currentTarget as HTMLElement).dataset.date;
  if (!iso) return;
  const d = parseIso(iso);
  // Naviger til riktig måned OG velg datoen som startdato — gir synlig
  // tilbakemelding (dagen markeres) også når vi allerede står på måneden,
  // og starter bookingen på første ledige dag.
  viewYear = d.getFullYear(); viewMonth = d.getMonth();
  selectedFrom = iso;
  selectedTo = null;
  renderCalendar();
  updateBookingForm();
  document.getElementById('cal')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

// Nav-knapper
btnPrev.addEventListener('click', () => {
  viewMonth--;
  if (viewMonth < 0) { viewMonth = 11; viewYear--; }
  renderCalendar();
});
btnNext.addEventListener('click', () => {
  viewMonth++;
  if (viewMonth > 11) { viewMonth = 0; viewYear++; }
  renderCalendar();
});

// Hent availability.json og easter-datoer, render
async function init() {
  try {
    const res = await fetch(`${base}/availability.json`);
    if (res.ok) availability = await res.json();
  } catch { /* Faller tilbake til tom liste */ }

  const ep = getRelevantEaster(new Date());
  easterDates = new Set(ep.allDates);

  renderCalendar();
  oppdaterNesteLedige();
}

init();

// Tegn kalenderen på nytt ved språkbytte (månedsnavn)
document.querySelectorAll('.lang button').forEach(b =>
  b.addEventListener('click', () => setTimeout(() => {
    renderCalendar();
    oppdaterNesteLedige();
    if (loddMeldingVist) visLoddMelding(new Date()); // hold meldingen i valgt språk
  }, 0)));
</script>
