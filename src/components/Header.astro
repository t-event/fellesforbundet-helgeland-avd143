---
import { ELSVATN_INATUR_URL } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const MIN_SIDE = 'https://minside.fellesforbundet.no';

// Full meny (åpnes av «Meny») som flerkolonne-megameny — fellesforbundet.no-stil.
const megaKolonner = [
  { tittel: 'Medlem', en: 'Member', lenker: [
    { href: '/bli-medlem',     label: 'Bli medlem',     en: 'Join' },
    { href: '/lonn-tariff',    label: 'Lønn & tariff',  en: 'Pay & agreements' },
    { href: '/tillitsvalgte',  label: 'Tillitsvalgte',  en: 'Shop stewards' },
    { href: '/nyttige-lenker', label: 'Nyttige lenker', en: 'Useful links' },
  ] },
  { tittel: 'Hytteutleie', en: 'Cabin rental', lenker: [
    { href: '/hytter',          label: 'Begge hyttene',          en: 'Both cabins' },
    { href: '/umbukta',         label: 'Hytte i Umbukta',        en: 'Umbukta cabin' },
    { href: ELSVATN_INATUR_URL, label: 'Hytte i Øvre Elsvatn ↗', en: 'Øvre Elsvatn cabin ↗', external: true },
    { href: '/turtips',         label: 'Turtips Umbukta',        en: 'Hiking tips (Umbukta)' },
    { href: '/hjelp',           label: 'Hjelp – hytteutleie',    en: 'Help – cabin rental' },
  ] },
  { tittel: 'Avdelingen', en: 'The branch', lenker: [
    { href: '/',        label: 'Hjem',        en: 'Home' },
    { href: '/om-oss',  label: 'Om oss',      en: 'About us' },
    { href: '/aktuelt', label: 'Aktuelt',     en: 'News' },
    { href: '/kontakt', label: 'Kontakt',     en: 'Contact' },
    { href: MIN_SIDE,   label: 'Min Side ↗',  en: 'My Page ↗', external: true },
  ] },
] as any[];

// Synlige snarveier i hovedraden (skjules på smale skjermer — da brukes «Meny»).
const snarveier = [
  { href: '/bli-medlem', label: 'Bli medlem',  en: 'Join' },
  { href: '/hytter',     label: 'Hytteutleie', en: 'Cabin rental' },
  { href: '/aktuelt',    label: 'Aktuelt',     en: 'News' },
  { href: '/kontakt',    label: 'Kontakt',     en: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
---

<header class="site-header" role="banner">
  <!-- Topp-rad: avdelings-snarveier + Min Side, språkvelger helt til høyre -->
  <div class="topbar">
    <div class="container topbar-inner">
      <nav class="topbar-nav" aria-label="Avdelings-snarveier">
        <a href={`${base}/om-oss`} class={currentPath === '/om-oss' ? 'active' : ''} data-en="About the branch">Om avdelingen</a>
        <a href={`${base}/tillitsvalgte`} class={currentPath === '/tillitsvalgte' ? 'active' : ''} data-en="For shop stewards">For tillitsvalgte</a>
        <a href={MIN_SIDE} target="_blank" rel="noopener noreferrer" data-en="My Page ↗">Min Side ↗</a>
      </nav>
      <div class="lang" role="group" aria-label="Velg språk / Choose language">
        <button data-lang="nb" class="active" aria-label="Norsk" title="Norsk">
          <svg class="flag" viewBox="0 0 22 16" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <rect width="22" height="16" fill="#BA0C2F" />
            <rect x="6" width="4" height="16" fill="#fff" />
            <rect y="6" width="22" height="4" fill="#fff" />
            <rect x="7" width="2" height="16" fill="#00205B" />
            <rect y="7" width="22" height="2" fill="#00205B" />
          </svg>
        </button>
        <button data-lang="en" aria-label="English" title="English">
          <svg class="flag" viewBox="0 0 60 30" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <rect width="60" height="30" fill="#012169" />
            <path d="M0,0 60,30 M60,0 0,30" stroke="#fff" stroke-width="6" />
            <path d="M0,0 60,30 M60,0 0,30" stroke="#C8102E" stroke-width="4" />
            <path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10" />
            <path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Hovedrad: logo + synlige snarveier + Meny-knapp -->
  <div class="container header-main">
    <a href={`${base}/`} class="brand" aria-label="Fellesforbundet Helgeland avd. 143 – til forsiden">
      <img
        src={`${base}/images/logo/ff_logo_hvit_rgb.svg`}
        alt="Fellesforbundet Helgeland"
        height="40"
        loading="eager"
        class="brand-logo"
      />
      <span class="brand-avd">
        <b class="brand-avd-1">Helgeland</b>
        <span class="brand-avd-2" data-en="Branch 143">Avd. 143</span>
      </span>
    </a>

    <div class="nav-right">
      <nav class="nav-shortcuts" aria-label="Hurtiglenker">
        {snarveier.map(l => (
          <a href={`${base}${l.href}`} class={currentPath === l.href ? 'active' : ''} data-en={l.en}>{l.label}</a>
        ))}
      </nav>
      <button
        class="meny-btn"
        id="nav-toggle"
        aria-label="Åpne meny"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span class="meny-ic meny-ic-apne" aria-hidden="true">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="17" y2="6"/><line x1="3" y1="10" x2="17" y2="10"/><line x1="3" y1="14" x2="17" y2="14"/></svg>
        </span>
        <span class="meny-ic meny-ic-lukk" aria-hidden="true">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="5" x2="15" y2="15"/><line x1="15" y1="5" x2="5" y2="15"/></svg>
        </span>
        <span class="meny-txt meny-txt-apne" data-en="Menu">Meny</span>
        <span class="meny-txt meny-txt-lukk" data-en="Close">Lukk</span>
      </button>
    </div>
  </div>
</header>

<!-- Full meny (megameny, åpnes av «Meny» på alle skjermstørrelser) -->
<nav class="megameny" id="nav-mobile" aria-label="Meny" role="navigation">
  <div class="container megameny-inner">
    {megaKolonner.map(kol => (
      <div class="megameny-kol">
        <div class="megameny-tittel" data-en={kol.en}>{kol.tittel}</div>
        <span class="tripp" aria-hidden="true"><i></i><i></i><i></i></span>
        <ul class="megameny-lenker">
          {kol.lenker.map((l: any) => (
            <li>
              <a
                href={l.external ? l.href : `${base}${l.href}`}
                class={!l.external && currentPath === l.href ? 'active' : ''}
                data-en={l.en}
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener noreferrer' : undefined}
              >{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</nav>
