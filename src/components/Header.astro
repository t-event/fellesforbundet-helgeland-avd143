---
import { ELSVATN_INATUR_URL } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: '/',                label: 'Forside',        key: 'nav_home'    },
  { href: '/umbukta',         label: 'Umbukta',        key: 'nav_umbukta' },
  { href: ELSVATN_INATUR_URL, label: 'Øvre Elsvatn ↗', key: 'nav_elsvatn', external: true },
  { href: '/turtips',         label: 'Turtips',        key: 'nav_turtips' },
  { href: '/hjelp',           label: 'Hjelpesenter',   key: 'nav_hjelp'   },
];

const currentPath = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
---

<header class="site-header" role="banner">
  <div class="container">
    <a href={`${base}/`} class="brand" aria-label="Fellesforbundet Helgeland Hytteutleie – til forsiden">
      <img
        src={`${base}/images/logo/ff_logo_hvit_rgb.svg`}
        alt="Fellesforbundet Helgeland"
        height="40"
        loading="eager"
        class="brand-logo"
      />
      <span class="brand-sub" data-en="Helgeland cabin rental">Helgeland hytteutleie</span>
    </a>

    <div class="nav-right">
      <!-- Desktop-nav -->
      <nav class="nav" aria-label="Hovedmeny">
        {navLinks.map(link => (
          <a
            href={link.external ? link.href : `${base}${link.href}`}
            class={!link.external && (currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) ? 'active' : ''}
            data-i18n={link.key}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Språkvelger (flagg-ikoner) -->
      <div class="lang" role="group" aria-label="Velg språk / Choose language">
        <button data-lang="nb" class="active" aria-label="Norsk" title="Norsk">
          <svg class="flag" viewBox="0 0 22 16" aria-hidden="true">
            <rect width="22" height="16" fill="#BA0C2F" />
            <rect x="6" width="4" height="16" fill="#fff" />
            <rect y="6" width="22" height="4" fill="#fff" />
            <rect x="7" width="2" height="16" fill="#00205B" />
            <rect y="7" width="22" height="2" fill="#00205B" />
          </svg>
        </button>
        <button data-lang="en" aria-label="English" title="English">
          <svg class="flag" viewBox="0 0 60 30" aria-hidden="true">
            <rect width="60" height="30" fill="#012169" />
            <path d="M0,0 60,30 M60,0 0,30" stroke="#fff" stroke-width="6" />
            <path d="M0,0 60,30 M60,0 0,30" stroke="#C8102E" stroke-width="4" />
            <path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10" />
            <path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6" />
          </svg>
        </button>
      </div>

      <!-- Hamburger (mobil) -->
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Åpne meny"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6"  x2="21" y2="6"  />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobilmeny (vises ved hamburger-klikk) -->
<nav class="nav-mobile" id="nav-mobile" aria-label="Mobilmeny" role="navigation">
  {navLinks.map(link => (
    <a
      href={link.external ? link.href : `${base}${link.href}`}
      class={!link.external && currentPath === link.href ? 'active' : ''}
      data-i18n={link.key}
      target={link.external ? '_blank' : undefined}
      rel={link.external ? 'noopener noreferrer' : undefined}
    >
      {link.label}
    </a>
  ))}
  <a href={`${base}/umbukta#ledige-datoer`} class="btn btn-primary" data-i18n="nav_book">
    Book Umbukta
  </a>
</nav>
