---
import { ELSVATN_INATUR_URL } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Én samlet avdelings-meny. Hytteutleia er en seksjon (dropdown), ikke et eget nettsted.
const navLinks = [
  { href: '/', label: 'Hjem', en: 'Home' },
  { label: 'Medlem', en: 'Member', children: [
    { href: '/bli-medlem',    label: 'Bli medlem',    en: 'Join' },
    { href: '/lonn-tariff',   label: 'Lønn & tariff', en: 'Pay & agreements' },
    { href: '/tillitsvalgte', label: 'Tillitsvalgte', en: 'Shop stewards' },
  ] },
  { href: '/aktuelt', label: 'Aktuelt',  en: 'News' },
  { href: '/kontakt', label: 'Kontakt',  en: 'Contact' },
  { label: 'Hytteutleie', en: 'Cabin rental', children: [
    { href: '/hytter',          label: 'Begge hyttene',      en: 'Both cabins' },
    { href: '/umbukta',         label: 'Hytte i Umbukta',    en: 'Umbukta cabin' },
    { href: ELSVATN_INATUR_URL, label: 'Øvre Elsvatn ↗',     en: 'Øvre Elsvatn ↗', external: true },
    { href: '/turtips',         label: 'Turtips',            en: 'Hiking tips' },
    { href: '/hjelp',           label: 'Hjelpesenter',       en: 'Help centre' },
  ] },
] as any[];

const currentPath = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
---

<header class="site-header" role="banner">
  <div class="container">
    <a href={`${base}/`} class="brand" aria-label="Fellesforbundet Helgeland avd. 143 – til forsiden">
      <img
        src={`${base}/images/logo/ff_logo_hvit_rgb.svg`}
        alt="Fellesforbundet Helgeland"
        height="40"
        loading="eager"
        class="brand-logo"
      />
      <span class="brand-sub" data-en="Helgeland · branch 143">Helgeland · avd. 143</span>
    </a>

    <div class="nav-right">
      <!-- Desktop-nav -->
      <nav class="nav" aria-label="Hovedmeny">
        {navLinks.map(link => (
          link.children ? (
            <div class="nav-group">
              <button class="nav-group-btn" type="button" aria-haspopup="true">
                <span data-en={link.en}>{link.label}</span><span class="caret" aria-hidden="true">▾</span>
              </button>
              <div class="nav-menu">
                {link.children.map((c: any) => (
                  <a
                    href={c.external ? c.href : `${base}${c.href}`}
                    class={!c.external && currentPath === c.href ? 'active' : ''}
                    data-en={c.en}
                    target={c.external ? '_blank' : undefined}
                    rel={c.external ? 'noopener noreferrer' : undefined}
                  >{c.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={`${base}${link.href}`}
              class={currentPath === link.href ? 'active' : ''}
              data-en={link.en}
            >
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- Språkvelger (flagg-ikoner) -->
      <div class="lang" role="group" aria-label="Velg språk / Choose language">
        <button data-lang="nb" class="active" aria-label="Norsk" title="Norsk">
          <svg class="flag" viewBox="0 0 22 16" aria-hidden="true">
            <rect width="22" height="16" fill="#BA0C2F" />
            <rect x="6" width="4" height="16" fill="#fff" />
            <rect y="6" width="22" height="4" fill="#fff" />
            <rect x="7" width="2" height="16" fill="#00205B" />
            <rect y="7" width="22" height="2" fill="#00205B" />
          </svg>
        </button>
        <button data-lang="en" aria-label="English" title="English">
          <svg class="flag" viewBox="0 0 60 30" aria-hidden="true">
            <rect width="60" height="30" fill="#012169" />
            <path d="M0,0 60,30 M60,0 0,30" stroke="#fff" stroke-width="6" />
            <path d="M0,0 60,30 M60,0 0,30" stroke="#C8102E" stroke-width="4" />
            <path d="M30,0 V30 M0,15 H60" stroke="#fff" stroke-width="10" />
            <path d="M30,0 V30 M0,15 H60" stroke="#C8102E" stroke-width="6" />
          </svg>
        </button>
      </div>

      <!-- Hamburger (mobil) -->
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Åpne meny"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6"  x2="21" y2="6"  />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobilmeny (vises ved hamburger-klikk) -->
<nav class="nav-mobile" id="nav-mobile" aria-label="Mobilmeny" role="navigation">
  {navLinks.map(link => (
    link.children ? (
      <Fragment>
        <div class="nav-m-label" data-en={link.en}>{link.label}</div>
        {link.children.map((c: any) => (
          <a
            href={c.external ? c.href : `${base}${c.href}`}
            class={`nav-m-sub${!c.external && currentPath === c.href ? ' active' : ''}`}
            data-en={c.en}
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
          >{c.label}</a>
        ))}
      </Fragment>
    ) : (
      <a
        href={`${base}${link.href}`}
        class={currentPath === link.href ? 'active' : ''}
        data-en={link.en}
      >
        {link.label}
      </a>
    )
  ))}
  <a href={`${base}/bli-medlem`} class="btn btn-primary" data-en="Become a member">Bli medlem</a>
</nav>
