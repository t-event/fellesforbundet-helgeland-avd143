---
import { KONTAKT } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();

const avdLinks = [
  { href: '/',              label: 'Hjem',          en: 'Home' },
  { href: '/bli-medlem',    label: 'Bli medlem',    en: 'Become a member' },
  { href: '/lonn-tariff',   label: 'Lønn & tariff', en: 'Pay & agreements' },
  { href: '/tillitsvalgte', label: 'Tillitsvalgte', en: 'Shop stewards' },
  { href: '/aktuelt',       label: 'Aktuelt',       en: 'News' },
  { href: '/nyttige-lenker',label: 'Nyttige lenker',en: 'Useful links' },
  { href: '/kontakt',       label: 'Kontakt',       en: 'Contact' },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="container" style="padding-top:clamp(40px,5vw,60px); padding-bottom:30px;">
    <div class="footer-cols">

      <!-- Merkevare -->
      <div class="footer-brand">
        <a href={`${base}/`} class="brand" style="margin-bottom:14px; text-decoration:none;" aria-label="Forside">
          <img
            src={`${base}/images/logo/ff_logo_hvit_rgb.svg`}
            alt="Fellesforbundet Helgeland"
            height="36"
            loading="lazy"
            class="brand-logo"
          />
        </a>
        <p data-en="Trade union for working people in Helgeland — we organise, negotiate and stand together.">
          Fagforening for arbeidsfolk på Helgeland — vi organiserer, forhandler og står sammen.
        </p>
        <a href={KONTAKT.facebookUrl} target="_blank" rel="noopener noreferrer" class="footer-social" data-en="Follow us on Facebook ↗">
          Følg oss på Facebook ↗
        </a>
      </div>

      <!-- Avdelingen -->
      <div>
        <h4 data-en="The branch">Avdelingen</h4>
        <ul>
          {avdLinks.map(l => (
            <li><a href={`${base}${l.href}`} data-en={l.en}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Hyttene -->
      <div>
        <h4 data-i18n="footer_hytter">Hyttene</h4>
        <ul>
          <li><a href={`${base}/hytter`} data-en="Both cabins">Begge hyttene</a></li>
          <li><a href={`${base}/umbukta`} data-en="Umbukta cabin">Hytte i Umbukta</a></li>
          <li>
            <a
              href="https://www.inatur.no/hytte/670e2bd422a51709667760cd/hytte-i-ovre-elsvatn-hattfjelldal"
              target="_blank"
              rel="noopener noreferrer"
              data-en="Øvre Elsvatn cabin ↗"
            >
              Hytte i Øvre Elsvatn ↗
            </a>
          </li>
          <li><a href={`${base}/turtips`} data-en="Hiking tips (Umbukta)">Turtips Umbukta</a></li>
          <li><a href={`${base}/vilkar`} data-en="Rental terms">Vilkår for leie</a></li>
          <li><a href={`${base}/hjelp`} data-en="Help – cabin rental">Hjelp – hytteutleie</a></li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h4 data-i18n="footer_kontakt">Kontakt</h4>
        <ul>
          <li>{KONTAKT.adresse}, {KONTAKT.postnummer} {KONTAKT.poststed}</li>
          <li><a href={`tel:+47${KONTAKT.telefon}`}>Tlf. {KONTAKT.telefonFormatert}</a></li>
          <li><a href={`mailto:${KONTAKT.epost}`}>{KONTAKT.epost}</a></li>
          <li><span data-en="Open">Åpent</span> {KONTAKT.apningstider}</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© <span id="footer-year">{year}</span> Fellesforbundet Helgeland avd. 143. <span data-en="All rights reserved.">Alle rettigheter reservert.</span></span>
      <span style="display:flex; gap:1.25rem; align-items:center; flex-wrap:wrap;">
        <a href={`${base}/om-oss`} style="color:inherit;" data-en="About">Om oss</a>
        <a href={`${base}/personvern`} style="color:inherit;" data-en="Privacy">Personvern</a>
        <a href={`${base}/cookies`} style="color:inherit;" data-en="Cookies">Cookies</a>
        <a href={`${base}/tilgjengelighet`} style="color:inherit;" data-en="Accessibility">Tilgjengelighet</a>
        <a href={KONTAKT.brreg} target="_blank" rel="noopener noreferrer" style="color:inherit;">
          Org.nr. {KONTAKT.orgnr}
        </a>
        <a href="https://t-event.no" target="_blank" rel="noopener noreferrer" style="color:inherit; opacity:0.7;">
          Utviklet av T-Event
        </a>
      </span>
    </div>
  </div>
</footer>

<script>
  // Auto-oppdaterende årstall (kjøres client-side for å alltid vise inneværende år)
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
