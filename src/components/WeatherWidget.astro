---
import { UMBUKTA, YR_URL, VEGVESEN_KAMERA_URL } from '../config.ts';
---

<div class="grid" style="grid-template-columns:1fr 1fr; align-items:stretch;">

  <!-- Vær fra MET -->
  <div class="weather" id="weather-widget">
    <div class="weather-top">
      <div>
        <b style="font-size:15px;">Umbukta</b>
        <div style="font-size:13px; color:var(--lysbla);" id="weather-dato" data-en="Loading weather…">Laster vær…</div>
      </div>
      <a href={YR_URL} target="_blank" rel="noopener noreferrer"
        style="font-size:13px; color:#cfd0e0; text-decoration:none;">
        yr.no ↗
      </a>
    </div>

    <div class="weather-temp">
      <span id="weather-icon" style="display:inline-flex; color:var(--lysgronn);" aria-hidden="true"></span>
      <div>
        <div class="deg" id="weather-temp">–</div>
        <div class="cond" id="weather-cond" style="font-size:15px;">–</div>
      </div>
    </div>

    <div class="weather-stats">
      <div class="weather-stat">
        <div class="k" data-en="Wind">Vind</div>
        <div class="v" style="display:flex; align-items:center; gap:5px;">
          <svg id="weather-vindpil" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            aria-hidden="true" style="opacity:0.85; transition:transform 0.4s ease; flex:none;">
            <path d="M12 2 L7.5 19 L12 14.5 L16.5 19 Z"/>
          </svg>
          <span id="weather-vind">–</span>
        </div>
        <div class="u"><span id="weather-vindretning" style="font-size:11px; opacity:0.7;"></span> m/s</div>
      </div>
      <div class="weather-stat">
        <div class="k" data-en="Precip.">Nedbør</div>
        <div class="v" id="weather-nedbor">–</div>
        <div class="u" data-en="mm/h">mm/t</div>
      </div>
      <div class="weather-stat">
        <div class="k" data-en="Pressure">Trykk</div>
        <div class="v" id="weather-trykk">–</div>
        <div class="u">hPa</div>
      </div>
    </div>

    <div class="weather-days" id="weather-days"></div>
  </div>

  <!-- Webkamera fra Statens vegvesen -->
  <div class="webcam">
    <div class="frame">
      <img
        id="webcam-img"
        src={`${VEGVESEN_KAMERA_URL}?t=${Date.now()}`}
        alt="Webkamera E12 ved Umbukta (Statens vegvesen)"
        style="width:100%; height:100%; object-fit:cover;"
        loading="lazy"
      />
      <span class="live" title="Oppdateres hvert 5. min" data-en="LIVE">DIREKTE</span>
    </div>
    <div class="meta">
      <span style="font-size:14px; font-weight:600;">E12 — Umbukta (Statens vegvesen)</span>
      <span class="muted" style="font-size:13px;" id="webcam-tid">–</span>
    </div>
  </div>

</div>

<script define:vars={{ LAT: UMBUKTA.lat, LON: UMBUKTA.lon, KAMERA_URL: VEGVESEN_KAMERA_URL }}>
const DAGER_NB = ['søn','man','tir','ons','tor','fre','lør'];
const DAYS_EN  = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const erEn = () => localStorage.getItem('lang') === 'en';

// Inline-SVG værsymboler (vendrede Lucide-ikoner) — erstatter emoji som
// rendres ulikt per OS. Fargen arves via currentColor.
const WX_ICONS = {
  'sun': '<circle cx="12" cy="12" r="4" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />',
  'moon': '<path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401" />',
  'cloud': '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z" />',
  'cloud-sun': '<path d="M12 2v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="M20 12h2" /><path d="m19.07 4.93-1.41 1.41" /><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128" /><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z" />',
  'cloud-moon': '<path d="M13 16a3 3 0 0 1 0 6H7a5 5 0 1 1 4.9-6z" /><path d="M18.376 14.512a6 6 0 0 0 3.461-4.127c.148-.625-.659-.97-1.248-.714a4 4 0 0 1-5.259-5.26c.255-.589-.09-1.395-.716-1.248a6 6 0 0 0-4.594 5.36" />',
  'cloud-rain': '<path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" /><path d="M16 14v6" /><path d="M8 14v6" /><path d="M12 16v6" />',
  'cloud-drizzle': '<path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" /><path d="M8 19v1" /><path d="M8 14v1" /><path d="M16 19v1" /><path d="M16 14v1" /><path d="M12 21v1" /><path d="M12 16v1" />',
  'cloud-snow': '<path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" /><path d="M8 15h.01" /><path d="M8 19h.01" /><path d="M12 17h.01" /><path d="M12 21h.01" /><path d="M16 15h.01" /><path d="M16 19h.01" />',
  'cloud-fog': '<path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" /><path d="M16 17H7" /><path d="M17 21H9" />',
  'cloud-lightning': '<path d="M6 16.326A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 .5 8.973" /><path d="m13 12-3 5h4l-3 5" />',
  'thermometer': '<path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z" />',
};
function wxSvg(name, size) {
  const inner = WX_ICONS[name] || WX_ICONS.thermometer;
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${inner}</svg>`;
}
const WX_BASE = {
  clearsky:'sun', fair:'cloud-sun', partlycloudy:'cloud-sun', cloudy:'cloud', fog:'cloud-fog',
  rain:'cloud-rain', lightrain:'cloud-drizzle', heavyrain:'cloud-rain',
  sleet:'cloud-snow', lightsleet:'cloud-snow', heavysleet:'cloud-snow',
  snow:'cloud-snow', lightsnow:'cloud-snow', heavysnow:'cloud-snow',
  rainandthunder:'cloud-lightning', lightrainandthunder:'cloud-lightning', heavyrainandthunder:'cloud-lightning',
  sleetandthunder:'cloud-lightning', snowandthunder:'cloud-lightning',
};
function iconName(code) {
  const b = symbolBase(code);
  if (/_night/.test(code || '')) {
    if (b === 'clearsky') return 'moon';
    if (b === 'fair' || b === 'partlycloudy') return 'cloud-moon';
  }
  return WX_BASE[b] || WX_BASE[b.replace(/andthunder$/, '')] || 'thermometer';
}

const SYMBOL_MAP = {
  clearsky: 'Sol', fair: 'Lettskyet', partlycloudy: 'Delvis skyet',
  cloudy: 'Skyet', fog: 'Tåke', rainandthunder: 'Tordenvær',
  rain: 'Regn', lightrain: 'Lett regn', heavyrain: 'Kraftig regn',
  snow: 'Snø', lightsnow: 'Lett snø', heavysnow: 'Kraftig snø',
  sleet: 'Sludd', lightsleet: 'Lett sludd', heavysleet: 'Kraftig sludd',
};

const SYMBOL_MAP_EN = {
  clearsky: 'Clear', fair: 'Fair', partlycloudy: 'Partly cloudy',
  cloudy: 'Cloudy', fog: 'Fog', rainandthunder: 'Thunderstorm',
  rain: 'Rain', lightrain: 'Light rain', heavyrain: 'Heavy rain',
  snow: 'Snow', lightsnow: 'Light snow', heavysnow: 'Heavy snow',
  sleet: 'Sleet', lightsleet: 'Light sleet', heavysleet: 'Heavy sleet',
};

function symbolBase(code) {
  return code ? code.replace(/_day|_night|_polartwilight/,'') : '';
}
function symbolLabel(code) {
  const b = symbolBase(code);
  return (erEn() ? SYMBOL_MAP_EN : SYMBOL_MAP)[b] ?? b.replace(/_/g,' ');
}

const COMPASS = ['N','NNØ','NØ','ØNØ','Ø','ØSØ','SØ','SSØ','S','SSV','SV','VSV','V','VNV','NV','NNV'];
const COMPASS_EN = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
function toCompass(deg) {
  return (erEn() ? COMPASS_EN : COMPASS)[Math.round(deg / 22.5) % 16];
}

async function fetchWeather() {
  try {
    const res = await fetch(
      `https://api.met.no/weatherapi/locationforecast/2.0/compact?lat=${LAT}&lon=${LON}`
    );
    if (!res.ok) throw new Error('MET API feil');
    const data = await res.json();
    const ts = data?.properties?.timeseries ?? [];
    if (!ts.length) return;

    const now = new Date();
    let nearest = ts[0];
    for (const t of ts) {
      if (new Date(t.time) <= now) nearest = t;
      else break;
    }
    const d    = nearest?.data;
    const inst = d?.instant?.details;

    const temp = inst?.air_temperature;
    document.getElementById('weather-temp').textContent =
      temp != null ? `${Math.round(temp)}°` : '–';

    const windSpeed = inst?.wind_speed;
    const windDir   = inst?.wind_from_direction;
    document.getElementById('weather-vind').textContent =
      windSpeed != null ? String(Math.round(windSpeed)) : '–';

    if (windDir != null) {
      // Pilen peker dit vinden blåser (FROM + 180°)
      document.getElementById('weather-vindpil').style.transform = `rotate(${windDir + 180}deg)`;
      document.getElementById('weather-vindretning').textContent = toCompass(windDir) + ' ';
    }

    document.getElementById('weather-nedbor').textContent =
      d?.next_1_hours?.details?.precipitation_amount != null
        ? String(d.next_1_hours.details.precipitation_amount) : '0';
    document.getElementById('weather-trykk').textContent =
      inst?.air_pressure_at_sea_level != null
        ? String(Math.round(inst.air_pressure_at_sea_level)) : '–';

    const sym = d?.next_1_hours?.summary?.symbol_code ?? d?.next_6_hours?.summary?.symbol_code;
    document.getElementById('weather-icon').innerHTML = wxSvg(iconName(sym), 44);
    document.getElementById('weather-cond').textContent = sym ? symbolLabel(sym) : '–';
    document.getElementById('weather-dato').textContent =
      now.toLocaleDateString(erEn() ? 'en-GB' : 'nb-NO', { weekday:'long', hour:'2-digit', minute:'2-digit' });

    // 5-dagers prognose — finn oppføring nærmest kl. 12 UTC for hver fremtidig dato
    const dagMap = {};
    for (const t of ts) {
      const d2 = new Date(t.time);
      if (d2 <= now) continue;
      const key = d2.toISOString().split('T')[0];
      const utcH = d2.getUTCHours();
      if (!dagMap[key]) {
        dagMap[key] = { date: d2, data: t.data, dist: Math.abs(utcH - 12) };
      } else if (Math.abs(utcH - 12) < dagMap[key].dist) {
        dagMap[key] = { date: d2, data: t.data, dist: Math.abs(utcH - 12) };
      }
    }
    const dager5 = Object.values(dagMap).slice(0, 5);
    document.getElementById('weather-days').innerHTML = dager5.map(({ date, data }) => {
      const t2    = data?.instant?.details?.air_temperature;
      const prec  = data?.next_6_hours?.details?.precipitation_amount ?? 0;
      const sym2  = data?.next_6_hours?.summary?.symbol_code ?? data?.next_1_hours?.summary?.symbol_code;
      return `<div class="weather-day">
        <div class="wd-dag">${(erEn() ? DAYS_EN : DAGER_NB)[date.getDay()]}</div>
        <div class="wd-ic" aria-hidden="true">${wxSvg(iconName(sym2), 26)}</div>
        <div class="wd-temp">${t2 != null ? Math.round(t2) + '°' : '–'}</div>
        <div class="wd-prec">${prec > 0 ? prec + ' mm' : ''}</div>
      </div>`;
    }).join('');
  } catch {
    document.getElementById('weather-dato').textContent = erEn() ? 'Weather unavailable' : 'Vær ikke tilgjengelig';
  }
}

function oppdaterKamera() {
  const img = document.getElementById('webcam-img');
  const tid = document.getElementById('webcam-tid');
  if (img) img.src = `${KAMERA_URL}?t=${Date.now()}`;
  if (tid) tid.textContent = `${erEn() ? 'Updated' : 'Oppdatert'} ${new Date().toLocaleTimeString(erEn() ? 'en-GB' : 'nb-NO', { hour:'2-digit', minute:'2-digit' })}`;
}

fetchWeather();
oppdaterKamera();
setInterval(oppdaterKamera, 5 * 60 * 1000);

// Oppdater værtekst og kameratid ved språkbytte
document.querySelectorAll('.lang button').forEach(b =>
  b.addEventListener('click', () => setTimeout(() => { fetchWeather(); oppdaterKamera(); }, 0)));
</script>
