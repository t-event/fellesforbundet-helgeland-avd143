---
// Inline SVG-ikon fra vendrede Lucide-ikoner (ISC-lisens) i src/icons/.
// Erstatter emoji (som rendres ulikt per OS). Fargen arves via currentColor.
interface Props {
  name: string;
  size?: number;
  stroke?: number;
  class?: string;
}
const { name, size = 24, stroke = 2, class: klass = '' } = Astro.props;

const filer = import.meta.glob('../icons/*.svg', { query: '?raw', import: 'default', eager: true }) as Record<string, string>;
const raw = filer[`../icons/${name}.svg`];
if (!raw) throw new Error(`Icon: ukjent ikon «${name}» (mangler i src/icons/)`);

const svg = raw
  .replace(/<!--[\s\S]*?-->/g, '')                       // fjern lisens-kommentar (attribusjon ligger i denne fila)
  .replace(/\swidth="24"/, ` width="${size}"`)
  .replace(/\sheight="24"/, ` height="${size}"`)
  .replace(/stroke-width="2"/, `stroke-width="${stroke}"`)
  .replace(/class="lucide/, `aria-hidden="true" focusable="false" class="ffh-icon ${klass} lucide`)
  .trim();
---
<Fragment set:html={svg} />
