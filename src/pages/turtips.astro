---
import Layout from '../layouts/Layout.astro';
import { TURTIPS } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const vanskelighetFarge = {
  'Lett': 'var(--lysgronn)',
  'Middels': 'var(--gul)',
  'Krevende': 'var(--rosa)',
};
---

<Layout
  title="Turtips fra Umbukta — Fellesforbundet Helgeland Hytteutleie"
  description="Utforsk fjell og vatn rundt Umbukta. Turtips for alle nivåer — fra korte vandringer til krevende toppturer. Sauvasshytta, Oksskolten, Virvasshytta og mer."
  ogImage="/images/umbukta/509360428_23863111016672162_2775771386801520296_n.jpg"
>

  <!-- HERO -->
  <div class="hero-dark">
    <div class="container section">
      <span class="hero-pill" data-i18n="nav_turtips">Turtips</span>
      <h1 class="h1" style="font-size:clamp(28px,3.8vw,46px); margin-bottom:12px;"
          data-en="Hiking tips from Umbukta">
        Turtips fra Umbukta
      </h1>
      <p class="lead" style="max-width:54ch;"
         data-en="Mountains, lakes and an old trail right outside the cabin door. Here are some favourites in the area around Umbukta in Helgeland.">
        Fjell, vatn og gammel ferdselsvei rett utenfor hyttedøra. Her er noen favoritter
        i området rundt Umbukta på Helgeland.
      </p>
    </div>
  </div>

  <div class="container section">

    <p class="muted" style="font-size:15px; margin-bottom:24px; max-width:62ch;"
       data-en="These hiking tips are based around the cabin in Umbukta; tips for the Øvre Elsvatn cabin will be added later. Route info is based on UT.no — click ‘See on UT.no’ for the full description and map.">
      Disse turtipsene tar utgangspunkt i hytta i Umbukta; turtips for hytta i Øvre Elsvatn kommer senere. Ruteinfo er basert på UT.no — klikk «Se på UT.no» for full beskrivelse og kart.
    </p>

    <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px;">
      {TURTIPS.map(tur => (
        <article class="tur-card">
          <div class="body">
            <div class="meta">
              <span style={`background:${vanskelighetFarge[tur.vanskelighet] ?? 'var(--gra)'}; padding:3px 10px; border-radius:20px; color:var(--morkbla);`} data-en={tur.vanskelighet_en}>
                {tur.vanskelighet}
              </span>
              {' · '}
              <span data-en={[tur.distanse_en, tur.tid_en].filter(Boolean).join(' · ')}>{[tur.distanse, tur.tid].filter(Boolean).join(' · ')}</span>
            </div>
            <h3 class="h3" style="margin-bottom:8px;">{tur.navn}</h3>
            <p class="muted" style="font-size:14.5px; flex:1; line-height:1.6;" data-en={tur.beskrivelse_en}>{tur.beskrivelse}</p>
            <a href={tur.lenke} target="_blank" rel="noopener noreferrer" class="btn-link" style="font-size:14px; margin-top:12px; align-self:flex-start;" data-en="See on UT.no ↗">Se på UT.no ↗</a>
          </div>
        </article>
      ))}
    </div>

    <!-- Generell info -->
    <div class="section" style="padding-bottom:0;">
      <div class="alert alert-warn">
        <span class="ic">!</span>
        <div style="font-size:14.5px; line-height:1.7;">
          <span data-en="<strong>Remember:</strong> Check the weather before you go — use "><strong>Husk:</strong> Sjekk været før du drar — bruk </span><a href="https://www.yr.no/nb/v%C3%A6rvarsel/daglig-tabell/66.1659051,14.5832452/" target="_blank" rel="noopener noreferrer" class="btn-link">Yr.no for Umbukta</a><span data-en=". Tell someone where you are going. Bring proper clothing and enough food and drink. Fishing licences are bought locally.">.
          Fortell noen hvor du går. Ta med riktige klær og nok mat og drikke.
          Fiskekort kjøpes lokalt.</span>
        </div>
      </div>
    </div>

    <div style="text-align:center; padding-top:40px;">
      <p class="muted" style="font-size:15px; margin-bottom:20px;"
         data-en="Ready for the hike? Book the cabin in Umbukta and use it as your base.">
        Klar for turen? Book hytta i Umbukta og bruk den som base.
      </p>
      <a href={`${base}/umbukta#ledige-datoer`} class="btn btn-primary" data-en="Book the Umbukta cabin →">Book hytta i Umbukta →</a>
    </div>

  </div>
</Layout>
