---
import Layout from '../layouts/Layout.astro';
import CircleMotif from '../components/CircleMotif.astro';
import Icon from '../components/Icon.astro';
import { FF_LENKER, KONTAKT } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const fordeler = [
  { ikon: 'coins', tittel: 'Riktig lønn',       tittel_en: 'Fair pay',         body: 'Tariffavtalen sikrer minstelønn, tillegg og årlige lønnsoppgjør.', body_en: 'The collective agreement secures minimum pay, supplements and annual wage settlements.' },
  { ikon: 'scale', tittel: 'Trygghet på jobb',  tittel_en: 'Security at work',  body: 'Råd og støtte ved oppsigelse, permittering og konflikt — med apparatet i ryggen.', body_en: 'Advice and backing with dismissal, layoffs and conflict — with the union behind you.' },
  { ikon: 'shield-check', tittel: 'Forsikring',        tittel_en: 'Insurance',        body: 'Kollektiv innboforsikring og gunstige medlemsforsikringer inkludert.', body_en: 'Collective home contents insurance and favourable member insurance included.' },
  { ikon: 'graduation-cap', tittel: 'Kurs & utvikling',  tittel_en: 'Courses & growth', body: 'Faglig påfyll og skolering — for både medlemmer og tillitsvalgte.', body_en: 'Professional development and training — for members and shop stewards alike.' },
  { ikon: 'mountain', tittel: 'Medlemstilbud',     tittel_en: 'Member offers',    body: 'Rabatter, ferieboliger og leie av forbundets fjellhytter.', body_en: 'Discounts, holiday homes and rental of the union\'s mountain cabins.' },
  { ikon: 'megaphone', tittel: 'Innflytelse',       tittel_en: 'Influence',        body: 'Vær med å bestemme over egen arbeidshverdag og lokalsamfunn.', body_en: 'Help shape your own working life and local community.' },
];

const steg = [
  { n: '1', tittel: 'Fyll ut skjema',  tittel_en: 'Fill in the form',  body: 'Oppgi navn, arbeidsgiver og kontaktinfo. Tar under fem minutter.', body_en: 'Enter your name, employer and contact details. Takes under five minutes.' },
  { n: '2', tittel: 'Vi tar kontakt',  tittel_en: 'We get in touch',   body: 'Avdelingen hjelper deg med riktig avtaleområde og tariffavtale.', body_en: 'The branch helps you with the right agreement area and collective agreement.' },
  { n: '3', tittel: 'Du er medlem',    tittel_en: 'You\'re a member',  body: 'Du får medlemskort, tilgang til Min side og alle fordeler.', body_en: 'You get a membership card, access to My page and all benefits.' },
];
---

<Layout
  title="Bli medlem — Fellesforbundet Helgeland avd. 143"
  description="Bli medlem i Fellesforbundet avd. 143. Tariffavtaler, råd og støtte på jobb, forsikring og medlemsfordeler. Kontingent 1,5 % av bruttolønn."
>

  <!-- HERO -->
  <div class="hero-dark">
    <CircleMotif variant="mork-rod" class="hero-motif" />
    <div class="container section">
      <div class="hero-grid" style="align-items:center;">
        <div>
          <span class="hero-pill" data-en="Membership">Medlemskap</span>
          <h1 class="h1" style="margin-top:18px;" data-en="Join Fellesforbundet">Bli medlem i Fellesforbundet</h1>
          <p class="lead" style="max-width:52ch; margin-top:20px;"
             data-en="Over 160,000 members stand together for fair pay and a secure working life. Membership costs 1.5% of your gross salary — and gives you far more in return.">
            Over 180 000 medlemmer står sammen for skikkelig lønn og et trygt arbeidsliv. Medlemskapet
            koster 1,5 % av bruttolønna — og gir deg langt mer igjen.
          </p>
          <div class="hero-actions" style="margin-top:26px;">
            <a href={FF_LENKER.medlemskap} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-en="Become a member now →">Bli medlem nå →</a>
            <a href={`${base}/kontakt`} class="btn btn-ghost" data-en="Contact the branch">Kontakt avdelingen</a>
          </div>
        </div>
        <div class="hero-img">
          <img src={`${base}/images/hovedside/ff-knyttneve.png`} alt="Illustrasjon: knyttneve — symbol på samhold" width="1200" height="675" loading="eager" style="width:100%; height:100%; object-fit:cover;" />
        </div>
      </div>
    </div>
  </div>

  <div class="container">

    <!-- FORDELER -->
    <div class="section">
      <span class="eyebrow" data-en="Why join">Derfor bør du være medlem</span>
      <h2 class="h2" style="margin:6px 0 36px;" data-en="What you get as a member">Dette får du som medlem</h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:18px;">
        {fordeler.map(f => (
          <div class="benefit">
            <span class="benefit-ic" aria-hidden="true"><Icon name={f.ikon} size={22} /></span>
            <h3 class="h3" style="font-size:18px; margin-bottom:6px;" data-en={f.tittel_en}>{f.tittel}</h3>
            <p class="muted" style="font-size:14.5px; line-height:1.6;" data-en={f.body_en}>{f.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- KONTINGENT -->
    <div id="kontingent" class="section hs-anchor" style="padding-top:0;">
      <div class="grid grid-2" style="gap:clamp(28px,4vw,48px); align-items:center;">
        <div>
          <span class="eyebrow" data-en="Membership fee">Kontingent</span>
          <h2 class="h2" style="margin:6px 0 16px;" data-en="What does it cost?">Hva koster det?</h2>
          <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:14px;"
             data-en="The membership fee is <strong>1.5% of your gross salary</strong> (including a local rate that varies by branch), normally deducted from your pay and shown on your payslip.">
            Kontingenten er <strong>1,5 % av bruttolønna</strong> (inkludert en lokal sats som varierer
            mellom avdelinger), og trekkes normalt fra lønna og vises på lønnsslippen.
          </p>
          <p class="muted" style="font-size:15px; line-height:1.7;"
             data-en="There is also a reduced minimum fee if you are not working (on benefits or pension). The rates are set each year — see the current figures at Fellesforbundet.">
            Det finnes også en redusert minstekontingent hvis du ikke er i arbeid (på stønad eller
            pensjon). Satsene fastsettes årlig — se gjeldende beløp hos Fellesforbundet.
          </p>
          <a href={FF_LENKER.kontingent} target="_blank" rel="noopener noreferrer" class="btn-link" style="display:inline-block; margin-top:16px;" data-en="What does membership cost? ↗">Hva koster medlemskapet? ↗</a>
        </div>
        <div class="about-quote">
          <p data-en="&ldquo;The membership fee comes back to you through better pay and working conditions.&rdquo;">
            «Kontingenten kommer tilbake til deg gjennom bedre lønn og arbeidsvilkår.»
          </p>
        </div>
      </div>
    </div>

    <!-- SLIK MELDER DU DEG INN -->
    <div class="section" style="padding-top:0;">
      <span class="eyebrow" data-en="How to join">Slik melder du deg inn</span>
      <h2 class="h2" style="margin:6px 0 32px;" data-en="Three simple steps">Tre enkle steg</h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:18px;">
        {steg.map(s => (
          <div class="step">
            <span class="step-n" aria-hidden="true">{s.n}</span>
            <h3 class="h3" style="font-size:18px; margin-bottom:6px;" data-en={s.tittel_en}>{s.tittel}</h3>
            <p class="muted" style="font-size:14.5px; line-height:1.6;" data-en={s.body_en}>{s.body}</p>
          </div>
        ))}
      </div>
      <div class="cta-band" style="margin-top:32px;">
        <div>
          <h2 class="h2" style="color:#fff; font-size:clamp(22px,2.6vw,30px); max-width:20ch;" data-en="Ready to join?">Klar for å melde deg inn?</h2>
          <p style="color:#dcdce8; font-size:16px; margin-top:10px; max-width:46ch; line-height:1.6;"
             data-en="Sign up via Fellesforbundet, or contact the branch if you have questions.">
            Meld deg inn via Fellesforbundet, eller kontakt avdelingen hvis du lurer på noe.
          </p>
        </div>
        <a href={FF_LENKER.medlemskap} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-en="Become a member →">Bli medlem →</a>
      </div>
    </div>

  </div>
</Layout>
