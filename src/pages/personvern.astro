---
import Layout from '../layouts/Layout.astro';
import { KONTAKT } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Personvernerklæring — Fellesforbundet Helgeland Hytteutleie"
  description="Les om hvordan Fellesforbundet Helgeland avd. 143 behandler personopplysninger ved hyttebooking."
>
  <div class="container section" style="max-width:720px; margin:0 auto;">
    <h1 class="h1" style="font-size:clamp(26px,3.6vw,38px); margin-bottom:10px;" data-en="Privacy policy">Personvernerklæring</h1>
    <p class="muted" style="margin-bottom:32px;" data-en="Last updated: June 2026">Sist oppdatert: juni 2026</p>

    <div style="display:flex; flex-direction:column; gap:28px; font-size:16px; line-height:1.75; color:var(--tekst-dempet);">
      <section>
        <h2 style="font-size:20px; font-weight:800; color:var(--tekst); margin-bottom:8px;" data-en="Data controller">Behandlingsansvarlig</h2>
        <p>
          Fellesforbundet Helgeland avd. 143 · Søndre gate 13, 8624 Mo i Rana ·
          <span data-en="Org. no.">Org.nr.</span> {KONTAKT.orgnr} · <a href={`mailto:${KONTAKT.epost}`} class="btn-link">{KONTAKT.epost}</a>
        </p>
      </section>

      <section>
        <h2 style="font-size:20px; font-weight:800; color:var(--tekst); margin-bottom:8px;" data-en="What information do we collect?">Hvilke opplysninger samler vi inn?</h2>
        <p data-en="When you send a booking request or contact message via the website, we collect: name, email address, phone number, requested dates, member category and, where relevant, LO union.">
          Når du sender en bookingforespørsel eller kontaktmelding via nettsiden, samler vi inn:
          navn, e-postadresse, telefonnummer, ønskede datoer, prisgruppe og eventuelt LO-forbund.
        </p>
      </section>

      <section>
        <h2 style="font-size:20px; font-weight:800; color:var(--tekst); margin-bottom:8px;" data-en="Purpose and legal basis">Formål og grunnlag</h2>
        <p data-en="The information is used solely to process your booking request (GDPR art. 6(1)(b) — necessary to perform a contract). Contact enquiries are processed on the basis of legitimate interest (art. 6(1)(f)).">
          Opplysningene brukes utelukkende til å behandle din bookingforespørsel (GDPR art. 6(1)(b) — nødvendig
          for å oppfylle en avtale). Kontakthenvendelser behandles på grunnlag av berettiget interesse (art. 6(1)(f)).
        </p>
      </section>

      <section>
        <h2 style="font-size:20px; font-weight:800; color:var(--tekst); margin-bottom:8px;" data-en="Storage and deletion">Lagring og sletting</h2>
        <p data-en="The website does not store any personal data itself — all data is sent directly to the office's email inbox and to the form service Web3Forms (EU data processing). Information in emails is deleted in accordance with the office's internal routines.">
          Nettsiden lagrer ingen personopplysninger selv — alle data sendes direkte til avdelingens
          e-postinnboks og til skjematjenesten Web3Forms (EU-databehandling). Opplysninger i e-poster
          slettes i tråd med avdelingens interne rutiner.
        </p>
      </section>

      <section>
        <h2 style="font-size:20px; font-weight:800; color:var(--tekst); margin-bottom:8px;" data-en="Your rights">Dine rettigheter</h2>
        <p>
          <span data-en="You have the right to access, rectification, erasure and data portability. Contact us at ">Du har rett til innsyn, retting, sletting og dataportabilitet. Kontakt oss på </span><a href={`mailto:${KONTAKT.epost}`} class="btn-link">{KONTAKT.epost}</a><span data-en=" or phone "> eller tlf. </span>{KONTAKT.telefonFormatert}.
        </p>
        <p style="margin-top:8px;">
          <span data-en="You can also complain to the Norwegian Data Protection Authority: ">Du kan også klage til Datatilsynet: </span><a href="https://www.datatilsynet.no" target="_blank" rel="noopener noreferrer" class="btn-link">datatilsynet.no ↗</a>
        </p>
      </section>

      <section>
        <h2 style="font-size:20px; font-weight:800; color:var(--tekst); margin-bottom:8px;" data-en="Cookies">Informasjonskapsler (cookies)</h2>
        <p>
          <span data-en="The website uses only one cookie: ">Nettsiden bruker kun én cookie: </span><code>lang</code><span data-en=" — stores your chosen language (NO/EN) locally in the browser. No tracking or marketing cookies. See the "> — lagrer ditt valgte språk (NO/EN) lokalt i nettleseren.
          Ingen sporings- eller markedsføringscookies. Se </span><a href={`${base}/cookies`} class="btn-link" data-en="cookie page">cookie-siden</a><span data-en=" for details."> for detaljer.</span>
        </p>
      </section>
    </div>
  </div>
</Layout>
