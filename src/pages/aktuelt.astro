---
import Layout from '../../layouts/Layout.astro';
import { KONTAKT } from '../../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Aktuelt — Fellesforbundet Helgeland avd. 143"
  description="Siste nytt fra Fellesforbundet avd. 143 — tariff, arrangementer og medlemsinfo. Følg avdelingen på Facebook for løpende oppdateringer."
>

  <!-- HERO -->
  <div class="hero-dark">
    <div class="container section">
      <span class="hero-pill" data-en="News">Aktuelt</span>
      <h1 class="h1" style="max-width:16ch; margin-top:18px;" data-en="News from the branch">Nytt fra avdelingen</h1>
      <p class="lead" style="max-width:58ch; margin-top:20px;"
         data-en="Updates on agreements, events and member info. The branch posts current news on Facebook.">
        Oppdateringer om tariff, arrangementer og medlemsinfo. Avdelingen legger ut løpende nyheter
        på Facebook.
      </p>
    </div>
  </div>

  <div class="container">

    <!-- FØLG OSS -->
    <div class="section">
      <div class="grid" style="grid-template-columns:1fr 1fr; gap:clamp(28px,4vw,48px); align-items:start;">
        <div>
          <span class="eyebrow" data-en="Follow the branch">Følg avdelingen</span>
          <h2 class="h2" style="margin:6px 0 16px;" data-en="Latest news on Facebook">Siste nytt på Facebook</h2>
          <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:22px;"
             data-en="The branch shares news, events and updates on its Facebook page. The latest posts load directly here when you choose to show them.">
            Avdelingen deler nyheter, arrangementer og oppdateringer på Facebook-sida si. De siste
            innleggene lastes rett inn her når du velger å vise dem.
          </p>
          <a href={KONTAKT.facebookUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-en="Open Facebook ↗">Åpne Facebook ↗</a>
        </div>

        <!-- Facebook-innlegg: lastes automatisk når «Godta alle» er valgt (cookie-samtykke) -->
        <div class="fb-embed" id="fb-embed" data-href={KONTAKT.facebookUrl}>
          <div class="fb-placeholder">
            <span aria-hidden="true" style="font-size:32px;">📘</span>
            <p style="font-weight:800; margin:10px 0 4px;" data-en="Facebook posts require cookies">Facebook-innlegg krever informasjonskapsler</p>
            <p class="muted" style="font-size:13px; max-width:38ch; margin:0 auto 16px; line-height:1.5;"
               data-en="Embedded posts load from facebook.com, which sets cookies. Accept cookies to view them here.">
              Innleggene hentes fra facebook.com, som setter informasjonskapsler. Godta informasjonskapsler for å se dem her.
            </p>
            <button class="btn btn-primary" id="fb-load" type="button" data-en="Accept cookies & show posts">Godta og vis innlegg</button>
          </div>
        </div>
      </div>
    </div>

    <!-- KONTAKT-STRIPE -->
    <div class="section" style="padding-top:0;">
      <div class="cta-band">
        <div>
          <h2 class="h2" style="color:#fff; font-size:clamp(22px,2.6vw,30px); max-width:22ch;" data-en="Have a tip or a case?">Har du tips eller en sak?</h2>
          <p style="color:#dcdce8; font-size:16px; margin-top:10px; max-width:46ch; line-height:1.6;"
             data-en="Get in touch with the branch — we want to hear from members.">
            Ta kontakt med avdelingen — vi vil høre fra medlemmene.
          </p>
        </div>
        <a href={`${base}/kontakt`} class="btn btn-primary" data-en="Contact the branch →">Kontakt avdelingen →</a>
      </div>
    </div>

  </div>
</Layout>

<style>
  .fb-embed { border: 1px solid var(--kantlinje); border-radius: 16px; overflow: hidden; background: var(--flate); min-height: 320px; display: flex; }
  .fb-placeholder { margin: auto; text-align: center; padding: 40px 24px; }
  .fb-embed iframe { display: block; width: 100%; border: 0; }
</style>

<script>
  const wrap = document.getElementById('fb-embed');
  let lastet = false;

  function lastFacebook() {
    if (!wrap || lastet) return;
    lastet = true;
    const href = wrap.getAttribute('data-href') || '';
    const src = 'https://www.facebook.com/plugins/page.php?href=' + encodeURIComponent(href)
      + '&tabs=timeline&width=500&height=720&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=false';
    const ifr = document.createElement('iframe');
    ifr.src = src;
    ifr.style.cssText = 'width:100%;height:720px;border:0;overflow:hidden;';
    ifr.setAttribute('scrolling', 'no');
    ifr.setAttribute('frameborder', '0');
    ifr.setAttribute('allowfullscreen', 'true');
    ifr.setAttribute('allow', 'autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share');
    ifr.setAttribute('loading', 'lazy');
    ifr.title = 'Facebook-innlegg fra Fellesforbundet Helgeland avd. 143';
    wrap.innerHTML = '';
    wrap.appendChild(ifr);
  }

  // Auto-last hvis brukeren allerede har godtatt alle informasjonskapsler.
  let samtykke: string | null = null;
  try { samtykke = localStorage.getItem('samtykke'); } catch (e) {}
  if (samtykke === 'alle') lastFacebook();

  // Last når samtykke gis (banner eller knappen under).
  document.addEventListener('samtykke-endret', (e) => {
    if ((e as CustomEvent).detail === 'alle') lastFacebook();
  });

  // Knappen i notisen: godta alle + last.
  document.getElementById('fb-load')?.addEventListener('click', () => {
    try { localStorage.setItem('samtykke', 'alle'); } catch (e) {}
    document.dispatchEvent(new CustomEvent('samtykke-endret', { detail: 'alle' }));
  });
</script>
