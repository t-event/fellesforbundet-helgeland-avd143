---
import Layout from '../layouts/Layout.astro';
import CircleMotif from '../components/CircleMotif.astro';
import { KONTAKT } from '../config.ts';
import arrangementData from '../data/arrangementer.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Arrangementer hentes automatisk fra fellesforbundet.no (planlagt GitHub-jobb),
// se scripts/update-arrangementer.mjs. Filtrer bort passerte ved build også.
const MND = ['jan', 'feb', 'mar', 'apr', 'mai', 'jun', 'jul', 'aug', 'sep', 'okt', 'nov', 'des'];
const idag = new Date(); idag.setHours(0, 0, 0, 0);
const arrangementer = (arrangementData.arrangementer ?? [])
  .filter(a => new Date(a.dato) >= idag)
  .map(a => { const d = new Date(a.dato); return { ...a, dag: d.getDate(), mnd: MND[d.getMonth()], aar: d.getFullYear() }; });
---

<Layout
  title="Aktuelt — Fellesforbundet Helgeland avd. 143"
  description="Siste nytt fra Fellesforbundet avd. 143 — tariff, arrangementer og medlemsinfo. Følg avdelingen på Facebook for løpende oppdateringer."
>

  <!-- HERO -->
  <div class="hero-dark">
    <CircleMotif variant="mork-oransje" class="hero-motif" />
    <div class="container section">
      <span class="hero-pill" data-en="News">Aktuelt</span>
      <h1 class="h1" style="max-width:16ch; margin-top:18px;" data-en="News from the branch">Nytt fra avdelingen</h1>
      <p class="lead" style="max-width:60ch; margin-top:20px;"
         data-en="Follow the branch's news and updates on Facebook — and see upcoming courses and conferences in Nordland from Fellesforbundet.">
        Følg avdelingens nyheter og oppdateringer på Facebook — og se kommende kurs og konferanser
        i Nordland fra Fellesforbundet.
      </p>
    </div>
  </div>

  <div class="container">

    <!-- NYTT FRA AVDELINGEN + KURS/KONFERANSER — side ved side -->
    <div class="section">
      <div class="grid grid-2" style="gap:clamp(28px,4vw,44px); align-items:start;">

        <!-- Venstre: Facebook -->
        <div>
          <span class="eyebrow" data-en="Follow the branch">Følg avdelingen</span>
          <h2 class="h2" style="margin:6px 0 12px;" data-en="Latest news on Facebook">Siste nytt på Facebook</h2>
          <p class="muted" style="font-size:15.5px; line-height:1.65; margin-bottom:18px;"
             data-en="News, events and updates from the branch. The latest posts load here when you choose to show them.">
            Nyheter, arrangementer og oppdateringer fra avdelingen. De siste innleggene lastes
            inn her når du velger å vise dem.
          </p>
          <!-- Facebook-innlegg: lastes når «Godta alle» er valgt (cookie-samtykke) -->
          <div class="fb-embed" id="fb-embed" data-href={KONTAKT.facebookUrl}>
            <div class="fb-placeholder">
              <span aria-hidden="true" style="font-size:32px;">📘</span>
              <p style="font-weight:800; margin:10px 0 4px;" data-en="Facebook posts require cookies">Facebook-innlegg krever informasjonskapsler</p>
              <p class="muted" style="font-size:13px; max-width:38ch; margin:0 auto 16px; line-height:1.5;"
                 data-en="Embedded posts load from facebook.com, which sets cookies. Accept cookies to view them here.">
                Innleggene hentes fra facebook.com, som setter informasjonskapsler. Godta informasjonskapsler for å se dem her.
              </p>
              <button class="btn btn-primary" id="fb-load" type="button" data-en="Accept cookies & show posts">Godta og vis innlegg</button>
            </div>
          </div>
          <a href={KONTAKT.facebookUrl} target="_blank" rel="noopener noreferrer" class="btn-link" style="display:inline-block; margin-top:16px;" data-en="Open Facebook ↗">Åpne Facebook ↗</a>
        </div>

        <!-- Høyre: Kurs & konferanser (kilde: fellesforbundet.no) -->
        <div>
          <span class="eyebrow" data-en="Courses & conferences">Kurs & konferanser</span>
          <h2 class="h2" style="margin:6px 0 12px;" data-en="Courses and conferences in Nordland">Kurs og konferanser i Nordland</h2>
          <p class="muted" style="font-size:15.5px; line-height:1.65; margin-bottom:18px;"
             data-en="From Fellesforbundet. Sign up via fellesforbundet.no.">
            Fra Fellesforbundet. Påmelding skjer på fellesforbundet.no.
          </p>

          {arrangementer.length > 0 ? (
            <div class="arr-liste">
              {arrangementer.slice(0, 6).map(a => (
                <a href={a.url} target="_blank" rel="noopener noreferrer" class="arr-item">
                  <span class="arr-dato" aria-hidden="true">
                    <span class="arr-mnd">{a.mnd}</span>
                    <span class="arr-dag">{a.dag}</span>
                  </span>
                  <span class="arr-body">
                    <span class={`arr-type${a.type === 'Konferanse' ? ' arr-type--konf' : ''}`}>{a.type}</span>
                    <b class="arr-tittel">{a.tittel} ↗</b>
                    <span class="muted arr-meta">{a.dag}. {a.mnd} {a.aar}{a.sted ? ` · ${a.sted}` : ''}</span>
                  </span>
                </a>
              ))}
            </div>
          ) : (
            <p class="muted" data-en="No upcoming courses or conferences registered right now.">Ingen kommende kurs eller konferanser registrert akkurat nå.</p>
          )}

          <a href={arrangementData.kildeUrl} target="_blank" rel="noopener noreferrer" class="btn-link" style="display:inline-block; margin-top:18px;" data-en="See all at fellesforbundet.no ↗">Se alle på fellesforbundet.no ↗</a>
        </div>

      </div>
    </div>

    <!-- KONTAKT-STRIPE -->
    <div class="section" style="padding-top:0;">
      <div class="cta-band">
        <div>
          <h2 class="h2" style="color:#fff; font-size:clamp(22px,2.6vw,30px); max-width:22ch;" data-en="Have a tip or a case?">Har du tips eller en sak?</h2>
          <p style="color:#dcdce8; font-size:16px; margin-top:10px; max-width:46ch; line-height:1.6;"
             data-en="Get in touch with the branch — we want to hear from members.">
            Ta kontakt med avdelingen — vi vil høre fra medlemmene.
          </p>
        </div>
        <a href={`${base}/kontakt`} class="btn btn-primary" data-en="Contact the branch →">Kontakt avdelingen →</a>
      </div>
    </div>

  </div>
</Layout>

<style>
  .fb-embed { border: 1px solid var(--kantlinje); border-radius: 4px; overflow: hidden; background: var(--flate); min-height: 320px; display: flex; justify-content: center; }
  .fb-placeholder { margin: auto; text-align: center; padding: 40px 24px; }
  .fb-embed iframe { display: block; max-width: 100%; border: 0; }
</style>

<script>
  const wrap = document.getElementById('fb-embed');
  let lastet = false;

  function lastFacebook() {
    if (!wrap || lastet) return;
    lastet = true;
    const href = wrap.getAttribute('data-href') || '';
    // Facebook-plugin har fast pikselbredde (min 180, maks 500). Mål containeren
    // og be Facebook rendre til den bredden, ellers kuttes innlegget på mobil.
    const bredde = Math.max(180, Math.min(500, Math.floor(wrap.clientWidth) || 500));
    const src = 'https://www.facebook.com/plugins/page.php?href=' + encodeURIComponent(href)
      + '&tabs=timeline&width=' + bredde + '&height=720&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=false';
    const ifr = document.createElement('iframe');
    ifr.src = src;
    ifr.style.cssText = 'width:' + bredde + 'px;max-width:100%;height:720px;border:0;overflow:hidden;';
    ifr.setAttribute('scrolling', 'no');
    ifr.setAttribute('frameborder', '0');
    ifr.setAttribute('allowfullscreen', 'true');
    ifr.setAttribute('allow', 'autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share');
    ifr.setAttribute('loading', 'lazy');
    ifr.title = 'Facebook-innlegg fra Fellesforbundet Helgeland avd. 143';
    wrap.innerHTML = '';
    wrap.appendChild(ifr);
  }

  // Auto-last hvis brukeren allerede har godtatt alle informasjonskapsler.
  let samtykke: string | null = null;
  try { samtykke = localStorage.getItem('samtykke'); } catch (e) {}
  if (samtykke === 'alle') lastFacebook();

  // Last når samtykke gis (banner eller knappen under).
  document.addEventListener('samtykke-endret', (e) => {
    if ((e as CustomEvent).detail === 'alle') lastFacebook();
  });

  // Knappen i notisen: godta alle + last.
  document.getElementById('fb-load')?.addEventListener('click', () => {
    try { localStorage.setItem('samtykke', 'alle'); } catch (e) {}
    document.dispatchEvent(new CustomEvent('samtykke-endret', { detail: 'alle' }));
  });
</script>
