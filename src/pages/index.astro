---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CircleMotif from '../components/CircleMotif.astro';
import { KONTAKT, ANSATTE, FF_LENKER } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const fordeler = [
  { ikon: 'handshake', tittel: 'Lønn & tariff',     tittel_en: 'Pay & agreements', body: 'Vi forhandler tariffavtaler og sikrer deg riktig lønn og ordnede arbeidsforhold.', body_en: 'We negotiate collective agreements and secure fair pay and proper working conditions.' },
  { ikon: 'scale', tittel: 'Juridisk hjelp',    tittel_en: 'Legal help',       body: 'Gratis bistand i saker om arbeidsforhold, oppsigelse, lønn og rettigheter.', body_en: 'Free assistance in matters of employment, dismissal, pay and rights.' },
  { ikon: 'graduation-cap', tittel: 'Kurs & skolering',  tittel_en: 'Courses & training', body: 'Tilbud om kurs for medlemmer og tillitsvalgte gjennom hele året.', body_en: 'Courses for members and shop stewards throughout the year.' },
  { ikon: 'mountain', tittel: 'Medlemsfordeler',   tittel_en: 'Member benefits',   body: 'Forsikring, rabatter og leie av forbundets fjellhytter til medlemspris.', body_en: 'Insurance, discounts and rental of the union\'s mountain cabins at member prices.' },
];
---

<Layout
  title="Fellesforbundet Helgeland avd. 143 — fagforening for arbeidsfolk på Helgeland"
  description="Avdeling 143 organiserer medlemmer i industri, bygg, transport og service i hele Helgeland — fra Mo i Rana og innlandet til Helgelandskysten. Bli medlem, få juridisk hjelp, tariffavtaler og medlemsfordeler."
  ogImage="/images/og-default.jpg"
>

  <!-- HERO -->
  <div class="hero-dark">
    <CircleMotif variant="mork" class="hero-motif" />
    <div class="container section">
      <div class="hero-grid" style="align-items:center;">
        <div>
          <span class="hero-pill" data-en="Norway's largest union in the private sector">Norges største forbund i privat sektor</span>
          <h1 class="h1" style="margin-top:18px;" data-en="Standing together — for a safe working life in Helgeland">
            Vi står sammen — for et trygt arbeidsliv på Helgeland
          </h1>
          <p class="lead" style="max-width:54ch; margin-top:20px;"
             data-en="Fellesforbundet branch 143 organises members in industry, construction, transport and service across all of Helgeland — from Mo i Rana and the inland out to the Helgeland coast. We negotiate pay, give legal help and stand together when it matters.">
            Fellesforbundet avdeling 143 organiserer medlemmer i industri, bygg, transport og service
            i hele Helgeland — fra Mo i Rana og innlandet ut til Helgelandskysten. Vi forhandler lønn,
            gir juridisk hjelp og står sammen når det gjelder.
          </p>
          <div class="hero-actions" style="margin-top:26px;">
            <a href={`${base}/bli-medlem`} class="btn btn-primary" data-en="Become a member today">Bli medlem i dag</a>
            <a href={`${base}/kontakt`} class="btn btn-ghost" data-en="Contact the branch">Kontakt avdelingen</a>
          </div>
        </div>
        <div class="hero-img">
          <img
            src={`${base}/images/hovedside/1mai-tog-mo-i-rana.jpg`}
            alt="1. mai-tog gjennom Mo i Rana med avdelingens fane og røde faner, snøkledde fjell i bakgrunnen"
            width="1400"
            height="934"
            loading="eager"
            style="width:100%; height:100%; object-fit:cover;"
          />
        </div>
      </div>
      <div class="hero-stats">
        <div><b>160 000+</b><span data-en="members in Fellesforbundet">medlemmer i Fellesforbundet</span></div>
        <div><b>Helgeland</b><span data-en="from inland to coast">fra innland til kyst</span></div>
        <div><b>Avd. 143</b><span data-en="your local branch">din lokale avdeling</span></div>
      </div>
    </div>
  </div>

  <!-- FORDELER / VI HAR RYGGEN DIN -->
  <div id="fordeler" style="background:var(--flate); border-top:1px solid var(--kantlinje);">
    <div class="container section">
      <span class="eyebrow" data-en="This is what you get as a member">Dette får du som medlem</span>
      <h2 class="h2" style="margin:6px 0 36px;" data-en="We've got your back">Vi har ryggen din</h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:18px;">
        {fordeler.map(f => (
          <div class="benefit">
            <span class="benefit-ic" aria-hidden="true"><Icon name={f.ikon} size={22} /></span>
            <h3 class="h3" style="font-size:18px; margin-bottom:6px;" data-en={f.tittel_en}>{f.tittel}</h3>
            <p class="muted" style="font-size:14.5px; line-height:1.6;" data-en={f.body_en}>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- OM AVDELINGEN -->
  <div id="om" class="container section">
    <div class="grid grid-2" style="gap:clamp(32px,5vw,56px); align-items:center;">
      <div>
        <span class="eyebrow" data-en="About branch 143">Om avdeling 143</span>
        <h2 class="h2" style="margin:6px 0 18px;" data-en="A strong voice for working people in Helgeland">
          En sterk stemme for arbeidsfolk på Helgeland
        </h2>
        <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:16px;"
           data-en="Branch 143 covers the whole Helgeland region and brings members together across industries. We work for secure jobs, decent pay and an organised working life.">
          Avdeling 143 dekker hele Helgeland-regionen og samler medlemmer på tvers av bransjer.
          Vi jobber for trygge ansettelser, anstendig lønn og et organisert arbeidsliv.
        </p>
        <p class="muted" style="font-size:16.5px; line-height:1.7;"
           data-en="As a member you get access to shop stewards, legal assistance, training and a range of member benefits — including renting the union's mountain cabins at member prices.">
          Som medlem får du tilgang til tillitsvalgtapparat, juridisk bistand, kursing og en rekke
          medlemsfordeler — inkludert leie av forbundets fjellhytter til medlemspris.
        </p>
      </div>
      <figure class="testimonial">
        <span class="testimonial-mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="testimonial-quote" data-en="Here we'll feature a quote from a member — about what it has meant to stand together in the union.">
          Her kommer et sitat fra et medlem — om hva det har betydd å stå sammen i fagforeningen.
        </blockquote>
        <figcaption class="testimonial-by">
          <span class="testimonial-avatar" aria-hidden="true"><Icon name="user" size={20} /></span>
          <span>
            <b data-en="Name coming">Navn kommer</b>
            <span class="muted" data-en="Member of the branch">Medlem i avdelingen</span>
          </span>
        </figcaption>
        <span class="testimonial-flag" data-en="Placeholder — a real member quote will be added">Plassholder — ekte medlemssitat kommer</span>
      </figure>
    </div>
  </div>

  <!-- AKTUELT / NYHETER -->
  <div id="aktuelt" class="hs-anchor" style="background:var(--flate); border-top:1px solid var(--kantlinje);">
    <div class="container section">
      <div style="display:flex; flex-wrap:wrap; align-items:end; justify-content:space-between; gap:16px; margin-bottom:24px;">
        <div>
          <span class="eyebrow" data-en="News">Aktuelt</span>
          <h2 class="h2" style="margin-top:6px;" data-en="News from the branch">Nytt fra avdelingen</h2>
        </div>
        <a href={`${base}/aktuelt`} class="btn-link" data-en="All news →">Til Aktuelt →</a>
      </div>
      <div class="card card-pad" style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:24px;">
        <div>
          <h3 class="h3" style="margin-bottom:6px;" data-en="Latest news on Facebook">Siste nytt på Facebook</h3>
          <p class="muted" style="font-size:15px; max-width:52ch; line-height:1.6;"
             data-en="The branch posts news, events and updates on its Facebook page. Follow along to stay informed.">
            Avdelingen legger ut nyheter, arrangementer og oppdateringer på Facebook. Følg med for å
            holde deg oppdatert.
          </p>
        </div>
        <a href={KONTAKT.facebookUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary" data-en="Follow on Facebook ↗">Følg på Facebook ↗</a>
      </div>
    </div>
  </div>

  <!-- ANSATTE / TILLITSVALGTE -->
  <div id="ansatte" class="container section hs-anchor">
    <div style="display:flex; flex-wrap:wrap; align-items:end; justify-content:space-between; gap:16px; margin-bottom:24px;">
      <div>
        <span class="eyebrow" data-en="People in the branch">Folk i avdelingen</span>
        <h2 class="h2" style="margin-top:6px;" data-en="The branch's staff">Avdelingens ansatte</h2>
      </div>
      <a href={`${base}/tillitsvalgte`} class="btn-link" data-en="See staff and board →">Se ansatte og styret →</a>
    </div>
    <div class="alert alert-warn" style="margin:0 0 20px; max-width:680px;">
      <span class="ic">!</span>
      <div style="font-size:14px; line-height:1.6;"
           data-en="Placeholder — staff names and photos are added when the branch provides them. This only shows the layout.">
        Plassholder — navn og bilder på de ansatte fylles inn når avdelingen sender dem. Dette viser kun oppsettet.
      </div>
    </div>
    <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px;">
      {ANSATTE.slice(0, 4).map(a => (
        <div class="person">
          <span class="person-avatar" aria-hidden="true" style="background:#e4e4ec; color:#6b6b76;">
            <Icon name="user" size={20} />
          </span>
          <div>
            <b style="display:block; font-size:15px; color:var(--tekst-svak);" data-en="Name coming">Navn kommer</b>
            <span class="muted" style="font-size:13px;" data-en={a.rolle_en}>{a.rolle}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- BLI MEDLEM (CTA-band) -->
  <div id="bli-medlem" class="container" style="padding-bottom:clamp(44px,6vw,72px);">
    <div class="cta-band">
      <div>
        <h2 class="h2" style="color:#fff; font-size:clamp(24px,3vw,34px); max-width:18ch;"
            data-en="Alone you are an employee. Together we are a movement.">
          Alene er du en ansatt. Sammen er vi en bevegelse.
        </h2>
        <p style="color:#dcdce8; font-size:16px; margin-top:12px; max-width:48ch; line-height:1.6;"
           data-en="Join in under five minutes. You become part of over 160,000 members in Fellesforbundet.">
          Meld deg inn på under fem minutter. Du blir en del av over 160 000 medlemmer i Fellesforbundet.
        </p>
      </div>
      <a href={FF_LENKER.medlemskap} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-en="Become a member →">
        Bli medlem →
      </a>
    </div>
  </div>

  <!-- HYTTE-TEASER (medlemsfordel) — grønt fremhevingsband (fellesforbundet.no-stil) -->
  <div id="hytte" class="container section">
    <div class="feature-band">
      <CircleMotif variant="gronn" class="feature-band-motif" />
      <div class="feature-band-media">
        <img
          src={`${base}/images/umbukta/umbukta-eksterior-terrasse.jpg`}
          alt="Fjellhytta i Umbukta — eksteriør med terrasse i solskinn"
          width="800"
          height="550"
          loading="lazy"
        />
      </div>
      <div class="feature-band-body">
        <span class="eyebrow" data-en="Member benefit">Medlemsfordel</span>
        <h2 class="h2" style="margin:6px 0 16px;" data-en="Rent a mountain cabin at member price">
          Leie fjellhytte til medlemspris
        </h2>
        <p style="font-size:16.5px; line-height:1.7; margin-bottom:22px;"
           data-en="The branch has cabins at Umbukta and Øvre Elsvatn, available to LO members. Check availability and book directly.">
          Avdelingen disponerer hytter ved Umbukta og Øvre Elsvatn, til leie for LO-medlemmer.
          Sjekk ledige datoer og book direkte.
        </p>
        <a href={`${base}/hytter`} class="btn btn-primary" data-en="See the cabins →">Se hyttene →</a>
      </div>
    </div>
  </div>

  <!-- KONTAKT -->
  <div id="kontakt" class="container section">
    <div class="card card-pad" style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:24px;">
      <div>
        <span class="eyebrow" data-en="Contact us">Kontakt oss</span>
        <h2 class="h2" style="font-size:clamp(22px,2.6vw,30px); margin:6px 0 10px;" data-en="Get in touch with the branch">
          Ta kontakt med avdelingen
        </h2>
        <p class="muted" style="font-size:15.5px; line-height:1.7;">
          <span data-en="Phone ">Telefon </span><a href={`tel:+47${KONTAKT.telefon}`} class="btn-link">{KONTAKT.telefonFormatert}</a>
          <span data-en=" · email "> · e-post </span><a href={`mailto:${KONTAKT.epost}`} class="btn-link">{KONTAKT.epost}</a><br />
          {KONTAKT.adresse}, {KONTAKT.poststed} · <span data-en="Open">Åpent</span> {KONTAKT.apningstider}
        </p>
      </div>
      <a href={`mailto:${KONTAKT.epost}`} class="btn btn-secondary" data-en="Send an email">Send e-post</a>
    </div>
  </div>

</Layout>

<style>
  @media (max-width: 768px) {
    .container .grid-2 { grid-template-columns: 1fr !important; }
  }
  /* Sticky header kompenseres ved hopp til ankerseksjoner (komponentstiler ligger i global.css) */
  #fordeler, #om, #aktuelt, #ansatte, #bli-medlem, #hytte, #kontakt { scroll-margin-top: 84px; }
</style>
