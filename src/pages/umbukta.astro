  </div>

  <!-- Sticky book-knapp (vises etter at hero er forbi, skjules når booking er synlig) -->
  <a href="#ledige-datoer" id="sticky-book" class="sticky-book btn btn-primary" data-en="Check availability →">
    Sjekk ledige datoer →
  </a>
</Layout>

<style>
  @media (max-width: 768px) {
    .section.grid-2 {
      grid-template-columns: 1fr !important;
    }
  }

  /* ── Galleri: hovedbilde + miniatyrer ─────────────────────── */
  .gallery-hero { display: flex; flex-direction: column; gap: 14px; }
  .gallery-main-wrap { position: relative; }
  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgba(26,24,54,0.55);
    color: #fff;
    font-size: 28px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    z-index: 2;
    transition: background 0.2s ease;
  }
  .gallery-nav:hover { background: rgba(26,24,54,0.88); }
  .gallery-nav.prev { left: 12px; }
  .gallery-nav.next { right: 12px; }
  @media (max-width: 600px) {
    .gallery-nav { width: 38px; height: 38px; font-size: 23px; }
    .gallery-nav.prev { left: 8px; }
    .gallery-nav.next { right: 8px; }
  }
  .gallery-main {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    padding: 0;
    border: none;
    background: none;
    border-radius: 4px;
    overflow: hidden;
    cursor: zoom-in;
    position: relative;
  }
  .gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .gallery-main:hover img { transform: scale(1.02); }
  .gallery-main::after {
    content: '⤢';
    position: absolute;
    bottom: 12px;
    right: 14px;
    color: #fff;
    font-size: 20px;
    opacity: 0.85;
    text-shadow: 0 1px 6px rgba(0,0,0,0.7);
  }
  .gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(92px, 1fr));
    gap: 10px;
  }
  .thumb {
    display: block;
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 2px solid transparent;
    background: none;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb.active { border-color: var(--rod); }
  .thumb:not(.active) img { opacity: 0.78; transition: opacity 0.2s; }
  .thumb:hover img { opacity: 1; }

  /* ── "Bra å vite"-skille ──────────────────────────────────── */
  .section-divider { border-top: 1px solid var(--kantlinje); }
  .eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rod);
  }

  /* ── Sticky book-knapp ────────────────────────────────────── */
  .sticky-book {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 60;
    box-shadow: 0 10px 28px rgba(26,24,54,0.32);
    opacity: 0;
    transform: translateY(14px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .sticky-book.show { opacity: 1; transform: none; pointer-events: auto; }
  @media (max-width: 600px) {
    .sticky-book { left: 16px; right: 16px; bottom: 16px; text-align: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    .sticky-book { transition: opacity 0.25s ease; transform: none; }
    .gallery-main img, .thumb img { transition: none; }
  }
</style>

<script>
  // ── Galleri: miniatyr bytter hovedbilde, hovedbilde åpner lightbox ──
  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb'));
  const mainBtn = document.getElementById('gallery-main');
  const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement | null;
  const lb    = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img') as HTMLImageElement | null;
  const lbCap = document.getElementById('lb-caption');
  let cur = 0;

  // Velg bildetekst etter aktivt språk (lagret i localStorage av Layout).
  const isEn = () => (localStorage.getItem('lang') || 'nb') === 'en';
  const altOf = (t: HTMLButtonElement) =>
    (isEn() ? (t.dataset.altEn || t.dataset.alt) : t.dataset.alt) || '';

  function setMain(i: number) {
    if (!thumbs.length) return;
    cur = (i + thumbs.length) % thumbs.length;
    const t = thumbs[cur];
    if (mainImg) {
      mainImg.src = t.dataset.src || '';
      mainImg.alt = altOf(t);
    }
    thumbs.forEach((el, idx) => el.classList.toggle('active', idx === cur));
  }

  function openLightbox(i: number) {
    if (!lb || !lbImg) return;
    cur = (i + thumbs.length) % thumbs.length;
    const t = thumbs[cur];
    lbImg.src = t.dataset.src || '';
    lbImg.alt = altOf(t);
    if (lbCap) lbCap.textContent = altOf(t);
    setMain(cur);
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    if (!lb) return;
    lb.style.display = 'none';
    document.body.style.overflow = '';
  }

  thumbs.forEach((t, i) => t.addEventListener('click', () => setMain(i)));
  mainBtn?.addEventListener('click', () => openLightbox(cur));
  document.getElementById('gallery-prev')?.addEventListener('click', () => setMain(cur - 1));
  document.getElementById('gallery-next')?.addEventListener('click', () => setMain(cur + 1));

  // Oppdater bildetekst når språket byttes (les ønsket språk fra knappen
  // for å unngå timing mot Layout sin applyLang).
  document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach(btn =>
    btn.addEventListener('click', () => {
      if (!thumbs.length) return;
      const t = thumbs[cur];
      const a = (btn.dataset.lang === 'en' ? (t.dataset.altEn || t.dataset.alt) : t.dataset.alt) || '';
      if (mainImg) mainImg.alt = a;
      if (lb && lb.style.display !== 'none') {
        if (lbImg) lbImg.alt = a;
        if (lbCap) lbCap.textContent = a;
      }
    })
  );
  document.getElementById('lb-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lb-prev')?.addEventListener('click', () => openLightbox(cur - 1));
  document.getElementById('lb-next')?.addEventListener('click', () => openLightbox(cur + 1));
  lb?.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (!lb || lb.style.display === 'none') return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') openLightbox(cur - 1);
    if (e.key === 'ArrowRight') openLightbox(cur + 1);
  });

  // ── Sticky book-knapp: vis når hero er forbi, skjul når booking er synlig ──
  const sticky = document.getElementById('sticky-book');
  const heroEl = document.querySelector('.media-hero');
  const bookEl = document.getElementById('ledige-datoer');
  if (sticky && heroEl && bookEl && 'IntersectionObserver' in window) {
    let pastHero = false;
    let bookVisible = false;
    const update = () => sticky.classList.toggle('show', pastHero && !bookVisible);
    new IntersectionObserver(([e]) => { pastHero = !e.isIntersecting; update(); })
      .observe(heroEl);
    new IntersectionObserver(([e]) => { bookVisible = e.isIntersecting; update(); }, { threshold: 0.12 })
      .observe(bookEl);
  }
</script>
