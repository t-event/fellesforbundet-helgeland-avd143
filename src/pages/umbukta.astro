</Layout>

<!-- Responsiv justering: stabel kalender+skjema på mobil -->
<style>
  @media (max-width: 768px) {
    .section.grid[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
  .galleri-btn {
    display: block;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
  }
  .galleri-btn img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.25s ease;
  }
  .galleri-btn:hover img { transform: scale(1.04); }
  .galleri-btn::after {
    content: '⤢';
    position: absolute;
    bottom: 8px;
    right: 10px;
    color: #fff;
    font-size: 18px;
    opacity: 0;
    transition: opacity 0.2s;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }
  .galleri-btn:hover::after { opacity: 1; }
</style>

<script>
  const btns = Array.from(document.querySelectorAll('.galleri-btn'));
  const lb    = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCap = document.getElementById('lb-caption');
  let cur = 0;

  function show(i) {
    cur = (i + btns.length) % btns.length;
    const btn = btns[cur];
    lbImg.src = btn.dataset.src;
    lbImg.alt = btn.dataset.alt;
    lbCap.textContent = btn.dataset.alt;
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
  }

  btns.forEach((btn, i) => btn.addEventListener('click', () => show(i)));
  document.getElementById('lb-close').addEventListener('click', close);
  document.getElementById('lb-prev').addEventListener('click', () => show(cur - 1));
  document.getElementById('lb-next').addEventListener('click', () => show(cur + 1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (lb.style.display === 'none') return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(cur - 1);
    if (e.key === 'ArrowRight') show(cur + 1);
  });
</script>
