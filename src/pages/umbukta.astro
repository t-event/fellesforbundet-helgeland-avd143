---
import Layout from '../layouts/Layout.astro';
import Calendar from '../components/Calendar.astro';
import BookingForm from '../components/BookingForm.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import EasterSection from '../components/EasterSection.astro';
import { PRISER, KONTAKT, UMBUKTA } from '../config.ts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const bilder = [
  { src: '159843138_3797277120348848_4595777890852669872_n.jpg',  alt: 'Hytte i Umbukta — eksteriør, solskinn og blå himmel' },
  { src: '480561933_1031634398995139_7564633413902508_n.jpg',     alt: 'Terrasse med utsikt over Umbukta og snødekte fjell' },
  { src: '509413152_23863110600005537_4089812885910828954_n.jpg', alt: 'Fullt utstyrt kjøkken med komfyr og kjøleskap' },
  { src: '510447695_23863110660005531_1894319381280647852_n.jpg', alt: 'Stor spisestue med langt bord — plass til alle' },
  { src: '509516086_23863110906672173_4310947696842304937_n.jpg', alt: 'Koselig stue med hjørnesofagruppe og store vinduer' },
  { src: '510195868_23863110700005527_2172912030040116231_n.jpg', alt: 'Kosehjørnet på hemsen — lenestoler og levende lys' },
  { src: '510147927_23863110696672194_1716070958571014737_n.jpg', alt: 'Soverom med køyeseng' },
  { src: '509364318_23863110756672188_7034588925113761005_n.jpg', alt: 'Bad med dusj og servant' },
];

const fasiliteter = [
  { ikon: '🛏', tittel: 'Inntil 14 sengeplasser', beskrivelse: '3 soverom + hems. Dyner og puter medfølger.' },
  { ikon: '🍳', tittel: 'Fullt kjøkken', beskrivelse: 'Komfyr, kjøleskap med fryser og kokeutstyr.' },
  { ikon: '⚡', tittel: 'Innlagt strøm', beskrivelse: '230V i hele hytta.' },
  { ikon: '💧', tittel: 'Innlagt vann', beskrivelse: 'Kaldt og varmt vann, dusj og toalett.' },
  { ikon: '🔥', tittel: 'Oppvarming', beskrivelse: 'Varmepumpe og vedovn.' },
  { ikon: '📺', tittel: 'WiFi og TV', beskrivelse: 'Mobildekning og internettilgang.' },
  { ikon: '🚗', tittel: 'Parkering', beskrivelse: 'Gratis — plass til 4–5 biler.' },
  { ikon: '🚤', tittel: 'Naust med båt', beskrivelse: 'Aluminiumsbåt med liten motor — ta med eget drivstoff.' },
  { ikon: '🐕', tittel: 'Hunder tillatt', beskrivelse: 'Hunder er velkomne — men ikke i sofa eller senger.' },
  { ikon: '🃏', tittel: 'Spill og fritid', beskrivelse: 'Kortstokk og yatzy finnes på hytta.' },
];

const faq = [
  {
    spm: 'Hva må jeg ta med?',
    svar: 'Du må ha med eget sengetøy og laken, håndklær, toalettpapir, kjøkkenhåndkle og øvrige forbruksvarer. Madrasser, dyner og puter finnes på hytta.'
  },
  {
    spm: 'Hvordan får jeg dørkoden?',
    svar: 'Avdelingen sender dørkoden til deg på SMS eller e-post etter at betalingen er registrert. Nøkkelen til hytta ligger i en nøkkelboks.'
  },
  {
    spm: 'Kan jeg avbestille og få refusjon?',
    svar: 'Avbestilt leie refunderes ikke. Ta kontakt med avdelingen for endring av dato. Vi anbefaler at du har reise-/avbestillingsforsikring i orden.'
  },
  {
    spm: 'Kan jeg ta med hund?',
    svar: 'Ja, hunder er tillatt. Men hunder skal ikke ligge i sofa eller senger. Gi gjerne beskjed i forespørselen din.'
  },
  {
    spm: 'Hvor langt fram i tid kan jeg booke?',
    svar: 'Kalenderen er som regel åpen. Unntak: påskeperioden fordeles ved loddtrekning (se seksjon over). Kontakt avdelingen hvis du er usikker.'
  },
  {
    spm: 'Hva skjer med bookingen min hvis to sender forespørsel på samme dato?',
    svar: 'Datoen er ikke reservert før avdelingen bekrefter og legger den inn i kalenderen. Avdelingen avgjør ved kollisjon — det er lav trafikk, så dette skjer sjelden.'
  },
  {
    spm: 'Er det elbillader?',
    svar: 'Nei, hytta har ikke elbillader. Det er heller ikke buss-/togadkomst eller handikaptilpasset innredning.'
  },
];
---

<Layout
  title="Hytte i Umbukta — Leie fjellhytte ved Rana | Fellesforbundet Helgeland"
  description="Lei hytta i Umbukta nær Mo i Rana og Sveriges grense. Inntil 14 sengeplasser, fullt utstyrt, sjekk ledige datoer og book her. Kun for LO-medlemmer — fra 700 kr/døgn."
  ogImage="/images/umbukta/159843138_3797277120348848_4595777890852669872_n.jpg"
  ogType="website"
>

  <!-- Schema.org for hytta -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "Hytte i Umbukta — Fellesforbundet Helgeland",
    "description": "Fjellhytte i Umbukta, Rana, eid av Fellesforbundet Helgeland avd. 143. Inntil 14 sengeplasser, fullt utstyrt. Kun for LO-medlemmer.",
    "url": Astro.site?.toString().replace(/\/$/, '') + base + '/umbukta',
    "image": [
      Astro.site?.toString().replace(/\/$/, '') + base + '/images/umbukta/159843138_3797277120348848_4595777890852669872_n.jpg',
    ],
    "geo": { "@type": "GeoCoordinates", "latitude": UMBUKTA.lat, "longitude": UMBUKTA.lon },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Umbukta",
      "addressRegion": "Rana",
      "addressCountry": "NO"
    },
    "priceRange": "700–1200 NOK/natt",
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Innlagt strøm", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Innlagt vann", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Parkering", "value": true },
    ],
    "telephone": "+47" + KONTAKT.telefon,
    "owner": {
      "@type": "Organization",
      "name": "Fellesforbundet Helgeland avd. 143",
      "url": KONTAKT.fellesforbundetUrl
    }
  })} slot="head" />

  <!-- HERO -->
  <div class="media-hero">
    <img
      src={`${base}/images/umbukta/159843138_3797277120348848_4595777890852669872_n.jpg`}
      alt="Hytte i Umbukta — fjellhytte i vakker natur ved Rana og Sveriges grense"
      width="1440"
      height="460"
      loading="eager"
      fetchpriority="high"
    />
    <div class="media-hero-overlay">
      <div class="container">
        <span class="badge badge-green" style="margin-bottom:16px;" data-i18n="umbukta_hero_badge">Hytte i Umbukta</span>
        <h1 class="h1" style="font-size:clamp(30px,4.6vw,52px);" data-i18n="umbukta_hero_title">
          Fjellhytta i Umbukta
        </h1>
        <p class="lead" style="color:#e2e2ee; margin-top:10px; max-width:50ch;" data-i18n="umbukta_hero_lead">
          Ved Umbukta fjellstue, ca. 3,5 mil fra Mo i Rana langs E12 — like ved riksgrensen til Sverige.
        </p>
      </div>
    </div>
  </div>

  <div class="container">

    <!-- OM HYTTA -->
    <div class="section grid" style="grid-template-columns:1fr 1fr; align-items:center; gap:clamp(32px,5vw,56px);">
      <div>
        <h2 class="h2" style="margin-bottom:16px;" data-i18n="umbukta_about_title">Om hytta</h2>
        <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:16px;">
          Umbukta-hytta ligger fritt til i fjellet, ca. 3,5 mil fra Mo i Rana langs E12, ca. 3 km fra grensen til Sverige.
          Hytta har plass til <strong>inntil 14 personer</strong> fordelt på 3 soverom og en romslig hems, med stue og fullt utstyrt kjøkken.
        </p>
        <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:16px;">
          Sommer som vinter er dette et utmerket utgangspunkt for friluftsliv på Helgeland —
          fiske, turer i fjellet og skiturer om vinteren. Like ved hytta finnes et naust med
          aluminiumsbåt og liten motor som kan lånes.
        </p>
        <p class="muted" style="font-size:15px; line-height:1.7;">
          <strong>Avstand fra vei: 0 km</strong> — gratis parkering til 4–5 biler rett ved hytta.
          Vinterstid kan veien inn til hytta være stengt; da parkeres det ved E12 og siste del
          gås på ski eller kjøres med snøscooter.
        </p>
      </div>
      <div style="height:clamp(240px,28vw,340px); border-radius:18px; overflow:hidden;">
        <img
          src={`${base}/images/umbukta/509364318_23863110756672188_7034588925113761005_n.jpg`}
          alt="Stua og kjøkkenet inne i Umbukta-hytta"
          width="800"
          height="600"
          loading="lazy"
          style="width:100%; height:100%; object-fit:cover;"
        />
      </div>
    </div>

    <!-- BILDEGALLERI -->
    <div class="section" style="padding-top:0;">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px); margin-bottom:22px;" data-i18n="umbukta_gallery_title">
        Bildegalleri
      </h2>
      <div class="gallery">
        {bilder.map(b => (
          <img
            src={`${base}/images/umbukta/${b.src}`}
            alt={b.alt}
            width="480"
            height="360"
            loading="lazy"
          />
        ))}
      </div>
    </div>

    <!-- FASILITETER -->
    <div class="facilities" style="margin-bottom:clamp(44px,6vw,64px);">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px);" data-i18n="umbukta_facilities_title">
        Fasiliteter
      </h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:16px;">
        {fasiliteter.map(f => (
          <div class="facility">
            <span class="facility-ic" aria-hidden="true">{f.ikon}</span>
            <div>
              <b>{f.tittel}</b>
              <span>{f.beskrivelse}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="alert alert-warn" style="margin-top:22px; padding:14px 16px;">
        <span class="ic">!</span>
        <div style="font-size:14.5px; line-height:1.6;">
          <strong>Ta med selv:</strong> Sengetøy og laken, håndklær, toalettpapir, kjøkkenhåndkle og andre forbruksvarer.
        </div>
      </div>
    </div>

    <!-- BELIGGENHET -->
    <div class="section grid" style="padding-top:0; grid-template-columns:1fr 1fr; gap:clamp(24px,4vw,44px); align-items:start;">
      <div style="min-height:320px; border-radius:18px; overflow:hidden;">
        <iframe
          title="Kart til Umbukta-hytta"
          src="https://www.google.com/maps/embed/v1/place?key=REMOVED-GOOGLE-API-KEY&q=66.1659051,14.5832452&zoom=12"
          width="100%"
          height="320"
          style="border:0; display:block; min-height:320px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          aria-label="Kart — Umbukta-hytta"
        ></iframe>
        <div style="padding:12px 16px; background:var(--flate); border-top:1px solid var(--kantlinje);">
          <a
            href={UMBUKTA.kart}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-link"
            style="font-size:14px;"
          >
            Åpne i Google Maps ↗
          </a>
          <span class="muted" style="font-size:13px; margin-left:12px;">
            GPS: {UMBUKTA.lat}°N, {UMBUKTA.lon}°Ø
          </span>
        </div>
      </div>
      <div class="card card-pad" data-i18n="umbukta_location_title">
        <h2 class="h2" style="font-size:24px; margin-bottom:18px;">Beliggenhet</h2>
        <div style="display:flex; flex-direction:column; gap:20px;">
          <div>
            <b style="font-size:15px;">Veibeskrivelse</b>
            <p class="muted" style="font-size:14.5px; margin-top:4px; line-height:1.6;">
              Fra Mo i Rana: Kjør E12 mot Sverige, ca. 3,5 mil (35 km). Ta av ved
              Umbukta — hytta ligger rett ved Umbukta fjellstue, ca. 3 km fra grensen.
            </p>
          </div>
          <div>
            <b style="font-size:15px;">Parkering</b>
            <p class="muted" style="font-size:14.5px; margin-top:4px;">
              Gratis parkering rett ved hytta — plass til 4–5 biler.
            </p>
          </div>
          <div>
            <b style="font-size:15px;">Vinteradkomst</b>
            <p class="muted" style="font-size:14.5px; margin-top:4px; line-height:1.6;">
              Grusvei inn til hytta kan være stengt om vinteren. Da parkeres ved E12 og
              siste strekning (ca. 2–3 km) gås på ski eller kjøres med snøscooter.
            </p>
          </div>
          <div>
            <b style="font-size:15px;">Uten bil</b>
            <p class="muted" style="font-size:14.5px; margin-top:4px;">
              Hytta er ikke tilgjengelig med buss eller tog. Bil er nødvendig.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- VÆR OG WEBKAMERA -->
    <div class="section" style="padding-top:0;">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px); margin-bottom:6px;" data-i18n="umbukta_weather_title">
        Vær &amp; webkamera
      </h2>
      <p class="muted" style="font-size:16px; margin-bottom:24px;" data-i18n="umbukta_weather_lead">
        Sjekk forholdene før du drar — oppdatert fra Umbukta.
      </p>
      <WeatherWidget />
    </div>

    <!-- PRISER -->
    <div class="section" style="padding-top:0;">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px); margin-bottom:6px;" data-i18n="umbukta_prices_title">
        Priser
      </h2>
      <p class="muted" style="font-size:16px; margin-bottom:28px;" data-i18n="umbukta_prices_lead">
        Alle priser er per døgn. Hytta er kun tilgjengelig for LO-medlemmer.
      </p>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px;">
        <div class="price-card featured">
          <span class="tag">Beste pris</span>
          <div class="label">Medlem Fellesforbundet Helgeland</div>
          <div class="amount">{PRISER.FFH}&nbsp;kr<small> /døgn</small></div>
        </div>
        <div class="price-card">
          <div class="label">Medlem Fellesforbundet (annen avd.)</div>
          <div class="amount">{PRISER.FF}&nbsp;kr<small> /døgn</small></div>
        </div>
        <div class="price-card">
          <div class="label">Medlem annet LO-forbund</div>
          <div class="amount">{PRISER.ANNET_LO}&nbsp;kr<small> /døgn</small></div>
        </div>
      </div>
      <div class="alert alert-warn" style="margin-top:18px;">
        <span class="ic">!</span>
        <div style="font-size:14.5px; line-height:1.6;">
          <strong>Avbestilling:</strong> Avbestilt leie refunderes ikke.
          Vi anbefaler reise-/avbestillingsforsikring. Kontakt avdelingen ved endringer.
        </div>
      </div>
    </div>

    <!-- KALENDER + BOOKINGSKJEMA -->
    <div class="section grid" style="padding-top:0; grid-template-columns:1fr 1fr; align-items:start; gap:clamp(20px,4vw,36px);">
      <div>
        <h2 class="h2" style="font-size:clamp(22px,2.6vw,28px); margin-bottom:18px;" data-i18n="umbukta_calendar_title">
          Ledige datoer
        </h2>
        <Calendar />
        <p class="muted" style="font-size:13px; margin-top:12px;">
          Klikk på en ledig dag for å velge fra-dato, deretter til-dato.
          Valgte datoer kopieres automatisk til skjemaet.
        </p>
      </div>
      <BookingForm />
    </div>

    <!-- PÅSKE / LODDTREKNING -->
    <div class="section" style="padding-top:0;">
      <EasterSection />
    </div>

    <!-- HUSREGLER + FAQ -->
    <div class="section grid" style="padding-top:0; grid-template-columns:1fr 1fr; align-items:start; gap:clamp(20px,4vw,36px);">

      <div class="rules" aria-label="Husregler">
        <h2 class="h2" style="font-size:24px;" data-i18n="umbukta_rules_title">
          Husregler &amp; praktisk info
        </h2>
        <div class="rule-row"><span class="k">Innsjekk</span><span class="v">fra kl. 16:00</span></div>
        <div class="rule-row"><span class="k">Utsjekk</span><span class="v">innen kl. 12:00</span></div>
        <div class="rule-row"><span class="k">Sengeplasser</span><span class="v">inntil 14</span></div>
        <div class="rule-row"><span class="k">Avbestilling</span><span class="v">Ingen refusjon</span></div>
        <div class="rule-row"><span class="k">Hunder</span><span class="v">Tillatt (ikke i seng/sofa)</span></div>
        <div class="rule-row"><span class="k">Røyking</span><span class="v">Ikke tillatt innendørs</span></div>
        <div class="rule-row"><span class="k">Elbillader</span><span class="v">Ikke tilgjengelig</span></div>
        <p class="note">
          Hytta skal forlates ryddig og rengjort av leietaker etter bruk.
          Nøkkel hentes i nøkkelboks på hytta — kode sendes av avdelingen etter bekreftet betaling.
        </p>
        <p class="note" style="margin-top:8px;">
          <strong>Foreninger</strong> og lignende kan låne hytta på hverdager uten overnatting —
          ta kontakt med avdelingen.
        </p>
      </div>

      <div>
        <h2 class="h2" style="font-size:24px; margin-bottom:18px;" data-i18n="umbukta_faq_title">
          Ofte stilte spørsmål
        </h2>
        <div class="accordion">
          {faq.map((f, i) => (
            <div class={`acc-item${i === 0 ? ' open' : ''}`}>
              <button class="acc-head">
                <b>{f.spm}</b>
                <span class="acc-icon" aria-hidden="true">+</span>
              </button>
              <div class="acc-body">{f.svar}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- KONTAKT-boks -->
    <div class="section" style="padding-top:0; padding-bottom:clamp(44px,6vw,72px);">
      <div class="card card-pad" style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:24px;">
        <div>
          <h3 class="h3" style="margin-bottom:6px;">Spørsmål om leie?</h3>
          <p class="muted" style="font-size:15px;">
            Ring oss på <a href={`tel:+47${KONTAKT.telefon}`} class="btn-link">{KONTAKT.telefonFormatert}</a>
            eller send e-post til <a href={`mailto:${KONTAKT.epost}`} class="btn-link">{KONTAKT.epost}</a>.
          </p>
          <p class="muted" style="font-size:13.5px; margin-top:4px;">Åpent {KONTAKT.apningstider}.</p>
        </div>
        <a href={`${base}/hjelp`} class="btn btn-secondary">Gå til hjelpesenter</a>
      </div>
    </div>

  </div>
</Layout>

<!-- Responsiv justering: stabel kalender+skjema på mobil -->
<style>
  @media (max-width: 768px) {
    .section.grid[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
