        <div>
          <h3 class="h3" style="margin-bottom:6px;" data-en="Questions about renting?">Spørsmål om leie?</h3>
          <p class="muted" style="font-size:15px;">
            <span data-en="Call us at ">Ring oss på </span><a href={`tel:+47${KONTAKT.telefon}`} class="btn-link">{KONTAKT.telefonFormatert}</a><span data-en=" or email "> eller send e-post til </span><a href={`mailto:${KONTAKT.epost}`} class="btn-link">{KONTAKT.epost}</a>.
          </p>
          <p class="muted" style="font-size:13.5px; margin-top:4px;"><span data-en="Open">Åpent</span> {KONTAKT.apningstider}.</p>
        </div>
        <a href={`${base}/hjelp`} class="btn btn-secondary" data-en="Go to help centre">Gå til hjelpesenter</a>
