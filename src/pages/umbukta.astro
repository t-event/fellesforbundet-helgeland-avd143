---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import Calendar from '../components/Calendar.astro';
import BookingForm from '../components/BookingForm.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import EasterSection from '../components/EasterSection.astro';
import MapEmbed from '../components/MapEmbed.astro';
import { PRISER, KONTAKT, UMBUKTA } from '../config.ts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const bilder = [
  { src: 'umbukta-eksterior-terrasse.jpg', alt: 'Hytte i Umbukta — eksteriør med terrasse i solskinn og blå himmel', alt_en: 'Umbukta cabin — exterior with terrace in sunshine and blue sky' },
  { src: 'umbukta-eksterior-vinduer.jpg',  alt: 'Eksteriør med store panoramavinduer mot Umbukta', alt_en: 'Exterior with large panoramic windows facing Umbukta' },
  { src: 'umbukta-stue.jpg',               alt: 'Lys stue med hjørnesofa, vedovn og store vinduer', alt_en: 'Bright living room with corner sofa, wood stove and large windows' },
  { src: 'umbukta-kjokken.jpg',            alt: 'Fullt utstyrt kjøkken med komfyr, kjøleskap og spisebord', alt_en: 'Fully equipped kitchen with stove, fridge and dining table' },
  { src: 'umbukta-spisestue-utsikt.jpg',   alt: 'Spisestue med panoramautsikt over Umbukta og fjellene', alt_en: 'Dining area with panoramic view over Umbukta and the mountains' },
  { src: 'umbukta-hems-sittegruppe.jpg',   alt: 'Sittegruppe på hemsen med lenestoler og utsikt over vatnet', alt_en: 'Seating area in the loft with armchairs and a view over the lake' },
  { src: 'umbukta-hems-senger.jpg',        alt: 'Romslig sovehems med flere sengeplasser', alt_en: 'Spacious sleeping loft with several beds' },
  { src: 'umbukta-soverom-dobbelt.jpg',    alt: 'Soverom med dobbeltseng og vindu mot naturen', alt_en: 'Bedroom with double bed and window facing nature' },
  { src: 'umbukta-soverom-koye.jpg',       alt: 'Soverom med køyeseng', alt_en: 'Bedroom with bunk bed' },
  { src: 'umbukta-bad.jpg',                alt: 'Bad med dusj, servant og toalett', alt_en: 'Bathroom with shower, sink and toilet' },
  { src: 'umbukta-naust-bat.jpg',          alt: 'Aluminiumsbåt med påhengsmotor i naustet', alt_en: 'Aluminium boat with outboard motor in the boathouse' },
];

const fasiliteter = [
  { ikon: 'bed-double', tittel: 'Inntil 12 sengeplasser', tittel_en: 'Up to 12 beds', beskrivelse: '2 soverom, sovealkove og romslig hems. Dyner og puter medfølger.', beskrivelse_en: '2 bedrooms, sleeping alcove and a spacious loft. Duvets and pillows included.' },
  { ikon: 'cooking-pot', tittel: 'Fullt kjøkken', tittel_en: 'Full kitchen', beskrivelse: 'Komfyr, kjøleskap med fryser og kokeutstyr.', beskrivelse_en: 'Stove, fridge with freezer and cookware.' },
  { ikon: 'zap', tittel: 'Innlagt strøm', tittel_en: 'Electricity', beskrivelse: '230V i hele hytta.', beskrivelse_en: '230V throughout the cabin.' },
  { ikon: 'droplet', tittel: 'Innlagt vann', tittel_en: 'Running water', beskrivelse: 'Kaldt og varmt vann, dusj og toalett.', beskrivelse_en: 'Cold and hot water, shower and toilet.' },
  { ikon: 'flame', tittel: 'Oppvarming', tittel_en: 'Heating', beskrivelse: 'Varmepumpe og vedovn.', beskrivelse_en: 'Heat pump and wood stove.' },
  { ikon: 'tv', tittel: 'WiFi og TV', tittel_en: 'WiFi and TV', beskrivelse: 'Mobildekning og internettilgang.', beskrivelse_en: 'Mobile coverage and internet access.' },
  { ikon: 'car-front', tittel: 'Parkering', tittel_en: 'Parking', beskrivelse: 'Gratis — plass til 4–5 biler.', beskrivelse_en: 'Free — space for 4–5 cars.' },
  { ikon: 'sailboat', tittel: 'Naust med båt', tittel_en: 'Boathouse with boat', beskrivelse: 'Aluminiumsbåt med liten motor kan lånes. Ta med eget drivstoff — 98 oktan, helst alkylatbensin (4-takt).', beskrivelse_en: 'Aluminium boat with small motor to borrow. Bring your own fuel — 98 octane, preferably alkylate petrol (4-stroke).' },
  { ikon: 'dog', tittel: 'Hunder tillatt', tittel_en: 'Dogs allowed', beskrivelse: 'Hunder er velkomne — men ikke i sofa eller senger.', beskrivelse_en: 'Dogs are welcome — but not on the sofa or beds.' },
  { ikon: 'ticket', tittel: 'Spill og fritid', tittel_en: 'Games & leisure', beskrivelse: 'Kortstokk og yatzy finnes på hytta.', beskrivelse_en: 'Playing cards and Yahtzee are available at the cabin.' },
];

const faq = [
  {
    spm: 'Hva må jeg ta med?',
    spm_en: 'What do I need to bring?',
    svar: 'Du må ha med eget sengetøy og laken, håndklær, toalettpapir, kjøkkenhåndkle og øvrige forbruksvarer. Madrasser, dyner og puter finnes på hytta.',
    svar_en: 'You need to bring your own bed linen and sheets, towels, toilet paper, a dish towel and other consumables. Mattresses, duvets and pillows are at the cabin.'
  },
  {
    spm: 'Hvordan får jeg dørkoden?',
    spm_en: 'How do I get the door code?',
    svar: 'Avdelingen sender dørkoden til deg på SMS eller e-post etter at betalingen er registrert. Nøkkelen til hytta ligger i en nøkkelboks.',
    svar_en: 'The office sends the door code to you by SMS or email once payment has been registered. The key to the cabin is in a key box.'
  },
  {
    spm: 'Kan jeg avbestille og få refusjon?',
    spm_en: 'Can I cancel and get a refund?',
    svar: 'Avbestilt leie refunderes ikke. Ta kontakt med avdelingen for endring av dato. Vi anbefaler at du har reise-/avbestillingsforsikring i orden.',
    svar_en: 'Cancelled bookings are not refunded. Contact the office to change the date. We recommend having travel/cancellation insurance in place.'
  },
  {
    spm: 'Kan jeg ta med hund?',
    spm_en: 'Can I bring a dog?',
    svar: 'Ja, hunder er tillatt. Men hunder skal ikke ligge i sofa eller senger. Gi gjerne beskjed i forespørselen din.',
    svar_en: 'Yes, dogs are allowed. But dogs must not lie on the sofa or beds. Please mention it in your request.'
  },
  {
    spm: 'Hva slags drivstoff bruker båtmotoren?',
    spm_en: 'What fuel does the boat motor use?',
    svar: 'Ta med eget drivstoff til den lille påhengsmotoren: 98 oktan, helst alkylatbensin (4-takt).',
    svar_en: 'Bring your own fuel for the small outboard motor: 98 octane, preferably alkylate petrol (4-stroke).'
  },
  {
    spm: 'Hvor langt fram i tid kan jeg booke?',
    spm_en: 'How far ahead can I book?',
    svar: 'Kalenderen er som regel åpen. Unntak: påskeperioden fordeles ved loddtrekning (se seksjon over). Kontakt avdelingen hvis du er usikker.',
    svar_en: 'The calendar is usually open. Exception: the Easter period is allocated by lottery (see the section above). Contact the office if you are unsure.'
  },
  {
    spm: 'Hva skjer med bookingen min hvis to sender forespørsel på samme dato?',
    spm_en: 'What happens to my booking if two people request the same date?',
    svar: 'Datoen er ikke reservert før avdelingen bekrefter og legger den inn i kalenderen. Avdelingen avgjør ved kollisjon — det er lav trafikk, så dette skjer sjelden.',
    svar_en: 'The date is not reserved until the office confirms it and enters it into the calendar. The office decides in case of a clash — traffic is low, so this rarely happens.'
  },
  {
    spm: 'Er det elbillader?',
    spm_en: 'Is there an EV charger?',
    svar: 'Hytta har ikke egen elbillader, men det finnes elbillader på Umbukta fjellstue ca. 300 m unna. Hytta har ikke buss-/togadkomst eller handikaptilpasset innredning.',
    svar_en: 'The cabin does not have its own EV charger, but there is an EV charger at Umbukta mountain lodge about 300 m away. The cabin has no bus/train access or wheelchair-accessible facilities.'
  },
];
---

<Layout
  title="Hytte i Umbukta — Leie fjellhytte ved Rana | Fellesforbundet Helgeland"
  description="Lei hytta i Umbukta nær Mo i Rana og Sveriges grense. Inntil 12 sengeplasser, fullt utstyrt, sjekk ledige datoer og book her. Kun for LO-medlemmer — fra 700 kr/døgn."
  ogImage="/images/umbukta/umbukta-eksterior-terrasse.jpg"
  ogType="website"
>

  <!-- Schema.org for hytta -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "Hytte i Umbukta — Fellesforbundet Helgeland",
    "description": "Fjellhytte i Umbukta, Rana, eid av Fellesforbundet Helgeland avd. 143. Inntil 12 sengeplasser, fullt utstyrt. Kun for LO-medlemmer.",
    "url": Astro.site?.toString().replace(/\/$/, '') + base + '/umbukta',
    "image": [
      Astro.site?.toString().replace(/\/$/, '') + base + '/images/umbukta/umbukta-eksterior-terrasse.jpg',
    ],
    "geo": { "@type": "GeoCoordinates", "latitude": UMBUKTA.lat, "longitude": UMBUKTA.lon },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Umbukta",
      "addressRegion": "Rana",
      "addressCountry": "NO"
    },
    "priceRange": "700–1200 NOK/natt",
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Innlagt strøm", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Innlagt vann", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Parkering", "value": true },
    ],
    "telephone": "+47" + KONTAKT.telefon,
    "owner": {
      "@type": "Organization",
      "name": "Fellesforbundet Helgeland avd. 143",
      "url": KONTAKT.fellesforbundetUrl
    }
  })} slot="head" />

  <!-- HERO -->
  <div class="media-hero">
    <img
      src={`${base}/images/umbukta/umbukta-eksterior-terrasse.jpg`}
      alt="Hytte i Umbukta — fjellhytte i vakker natur ved Rana og Sveriges grense"
      width="1440"
      height="460"
      loading="eager"
      fetchpriority="high"
    />
    <div class="media-hero-overlay">
      <div class="container">
        <span class="badge badge-green" style="margin-bottom:16px;" data-i18n="umbukta_hero_badge">Hytte i Umbukta</span>
        <h1 class="h1" style="font-size:clamp(30px,4.6vw,52px);" data-i18n="umbukta_hero_title">
          Fjellhytta i Umbukta
        </h1>
        <p class="lead" style="color:#e2e2ee; margin-top:10px; max-width:50ch;" data-i18n="umbukta_hero_lead">
          Ved Umbukta fjellstue, ca. 3,5 mil fra Mo i Rana langs E12 — like ved riksgrensen til Sverige.
        </p>
        <div style="margin-top:22px; display:flex; flex-wrap:wrap; gap:12px;">
          <a href="#ledige-datoer" class="btn btn-primary" data-en="Check availability and book →">Sjekk ledige datoer og book →</a>
        </div>
      </div>
    </div>
  </div>

  <div class="container">

    <!-- OM HYTTA -->
    <div class="section grid grid-2" style="align-items:center; gap:clamp(32px,5vw,56px);">
      <div>
        <h2 class="h2" style="margin-bottom:16px;" data-i18n="umbukta_about_title">Om hytta</h2>
        <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:16px;"
           data-en="The Umbukta cabin sits freely in the mountains, approx. 35 km from Mo i Rana along the E12, about 3 km from the Swedish border. The cabin sleeps <strong>up to 12 people</strong> across 2 bedrooms, a sleeping alcove and a spacious loft, with a living room and a fully equipped kitchen.">
          Umbukta-hytta ligger fritt til i fjellet, ca. 3,5 mil fra Mo i Rana langs E12, ca. 3 km fra grensen til Sverige.
          Hytta har plass til <strong>inntil 12 personer</strong> fordelt på 2 soverom, sovealkove og en romslig hems, med stue og fullt utstyrt kjøkken.
        </p>
        <p class="muted" style="font-size:16.5px; line-height:1.7; margin-bottom:16px;"
           data-en="Summer and winter alike, this is an excellent base for outdoor life in Helgeland — fishing, mountain hikes and skiing in winter. Right by the cabin there is a boathouse with an aluminium boat with a small motor that can be borrowed.">
          Sommer som vinter er dette et utmerket utgangspunkt for friluftsliv på Helgeland —
          fiske, turer i fjellet og skiturer om vinteren. Like ved hytta finnes et naust med
          aluminiumsbåt med liten motor som kan lånes.
        </p>
        <p class="muted" style="font-size:15px; line-height:1.7;"
           data-en="<strong>Distance from the road: 0 km</strong> — free parking for 4–5 cars right by the cabin. The road to the cabin is ploughed in winter, so you can drive all the way year-round.">
          <strong>Avstand fra vei: 0 km</strong> — gratis parkering til 4–5 biler rett ved hytta.
          Veien inn til hytta brøytes om vinteren, så du kan kjøre helt fram hele året.
        </p>
      </div>
      <div style="height:clamp(240px,28vw,340px); border-radius:4px; overflow:hidden;">
        <img
          src={`${base}/images/umbukta/umbukta-stue.jpg`}
          alt="Lys stue med hjørnesofa og vedovn inne i Umbukta-hytta"
          width="800"
          height="600"
          loading="lazy"
          style="width:100%; height:100%; object-fit:cover;"
        />
      </div>
    </div>

    <!-- BILDEGALLERI (hovedbilde + miniatyrer) -->
    <div class="section" style="padding-top:0;">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px); margin-bottom:22px;" data-i18n="umbukta_gallery_title">
        Bildegalleri
      </h2>
      <div class="gallery-hero">
        <div class="gallery-main-wrap">
          <button class="gallery-main" id="gallery-main" aria-label="Forstørr hovedbilde">
            <img
              id="gallery-main-img"
              src={`${base}/images/umbukta/${bilder[0].src}`}
              alt={bilder[0].alt}
              width="1200"
              height="750"
              loading="lazy"
            />
          </button>
          <button class="gallery-nav prev" id="gallery-prev" aria-label="Forrige bilde">‹</button>
          <button class="gallery-nav next" id="gallery-next" aria-label="Neste bilde">›</button>
        </div>
        <div class="gallery-thumbs" id="galleri">
          {bilder.map((b, i) => (
            <button
              class={`thumb${i === 0 ? ' active' : ''}`}
              aria-label={`Vis bilde: ${b.alt}`}
              data-src={`${base}/images/umbukta/${b.src}`}
              data-alt={b.alt}
              data-alt-en={b.alt_en}
            >
              <img
                src={`${base}/images/umbukta/${b.src}`}
                alt={b.alt}
                width="240"
                height="180"
                loading="lazy"
              />
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- LIGHTBOX -->
    <div id="lightbox" role="dialog" aria-modal="true" aria-label="Bildevisning" style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.92); align-items:center; justify-content:center; padding:20px;">
      <button id="lb-prev" aria-label="Forrige bilde" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.12); border:none; color:#fff; font-size:28px; width:48px; height:48px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center;">‹</button>
      <button id="lb-next" aria-label="Neste bilde" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.12); border:none; color:#fff; font-size:28px; width:48px; height:48px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center;">›</button>
      <button id="lb-close" aria-label="Lukk" style="position:absolute; top:16px; right:16px; background:rgba(255,255,255,0.12); border:none; color:#fff; font-size:22px; width:44px; height:44px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center;">✕</button>
      <img id="lb-img" src="" alt="" style="max-width:min(90vw,1200px); max-height:85vh; object-fit:contain; border-radius:4px; display:block;" />
      <p id="lb-caption" style="position:absolute; bottom:20px; left:50%; transform:translateX(-50%); color:#ccc; font-size:14px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:80vw;"></p>
    </div>

    <!-- PRISER -->
    <div class="section" style="padding-top:0;">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px); margin-bottom:6px;" data-i18n="umbukta_prices_title">
        Priser
      </h2>
      <p class="muted" style="font-size:16px; margin-bottom:28px;" data-i18n="umbukta_prices_lead">
        Alle priser er per døgn. Hytta er kun tilgjengelig for LO-medlemmer.
      </p>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px;">
        <div class="price-card featured">
          <span class="tag" data-en="Best price">Beste pris</span>
          <div class="label" data-en="Fellesforbundet Helgeland member">Medlem Fellesforbundet Helgeland</div>
          <div class="amount">{PRISER.FFH}&nbsp;kr<small data-en=" /night"> /døgn</small></div>
        </div>
        <div class="price-card">
          <div class="label" data-en="Fellesforbundet member (other branch)">Medlem Fellesforbundet (annen avd.)</div>
          <div class="amount">{PRISER.FF}&nbsp;kr<small data-en=" /night"> /døgn</small></div>
        </div>
        <div class="price-card">
          <div class="label" data-en="Member of another LO union">Medlem annet LO-forbund</div>
          <div class="amount">{PRISER.ANNET_LO}&nbsp;kr<small data-en=" /night"> /døgn</small></div>
        </div>
      </div>
      <div class="alert alert-warn" style="margin-top:18px;">
        <span class="ic">!</span>
        <div style="font-size:14.5px; line-height:1.6;" data-en={`<strong>Cancellation:</strong> Cancelled bookings are not refunded. We recommend travel/cancellation insurance. Contact the office for changes. See all <a href="${base}/vilkar" class="btn-link">rental terms</a>.`}>
          <strong>Avbestilling:</strong> Avbestilt leie refunderes ikke.
          Vi anbefaler reise-/avbestillingsforsikring. Kontakt avdelingen ved endringer.
          Se alle <a href={`${base}/vilkar`} class="btn-link">vilkår for leie</a>.
        </div>
      </div>
    </div>

    <!-- KALENDER + BOOKINGSKJEMA -->
    <div id="ledige-datoer" class="section grid grid-2" style="scroll-margin-top:90px; padding-top:0; align-items:start; gap:clamp(20px,4vw,36px);">
      <div>
        <h2 class="h2" style="font-size:clamp(22px,2.6vw,28px); margin-bottom:18px;" data-i18n="umbukta_calendar_title">
          Ledige datoer
        </h2>
        <Calendar />
        <p class="muted" style="font-size:13px; margin-top:12px;"
           data-en="Click an available day to choose the check-in date, then the check-out date. Selected dates are copied automatically into the form.">
          Klikk på en ledig dag for å velge fra-dato, deretter til-dato.
          Valgte datoer kopieres automatisk til skjemaet.
        </p>
      </div>
      <BookingForm />
    </div>

    <!-- PÅSKE / LODDTREKNING — skjult utenom påske. Ingen .section-wrapper her:
         luften ligger på #paske-seksjon selv, så en skjult seksjon ikke etterlater
         dødrom mellom skjemaet og «Bra å vite». -->
    <EasterSection />

    <!-- ── BRA Å VITE ─────────────────────────────────────────── -->
    <div class="section section-divider" style="padding-bottom:0;">
      <span class="eyebrow" data-en="Good to know">Bra å vite</span>
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px); margin-top:6px;" data-en="Facilities, location and house rules">
        Fasiliteter, beliggenhet og husregler
      </h2>
    </div>

    <!-- FASILITETER -->
    <div class="facilities" style="margin-bottom:clamp(44px,6vw,64px);">
      <h2 class="h2" style="font-size:clamp(22px,2.8vw,32px);" data-i18n="umbukta_facilities_title">
        Fasiliteter
      </h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:16px;">
        {fasiliteter.map(f => (
          <div class="facility">
            <span class="facility-ic" aria-hidden="true"><Icon name={f.ikon} size={22} /></span>
            <div>
              <b data-en={f.tittel_en}>{f.tittel}</b>
              <span data-en={f.beskrivelse_en}>{f.beskrivelse}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="alert alert-warn" style="margin-top:22px; padding:14px 16px;">
        <span class="ic">!</span>
        <div style="font-size:14.5px; line-height:1.6;" data-en="<strong>Bring yourself:</strong> Bed linen and sheets, towels, toilet paper, a dish towel and other consumables.">
          <strong>Ta med selv:</strong> Sengetøy og laken, håndklær, toalettpapir, kjøkkenhåndkle og andre forbruksvarer.
        </div>
      </div>
    </div>

    <!-- BELIGGENHET -->
    <div class="section grid grid-2" style="padding-top:0; gap:clamp(24px,4vw,44px); align-items:start;">
      <div style="display:flex; flex-direction:column; gap:16px;">
        <div style="border-radius:4px; overflow:hidden; display:flex; flex-direction:column;">
          <div style="height:320px;">
            <MapEmbed src={`https://www.google.com/maps?q=${UMBUKTA.lat},${UMBUKTA.lon}&hl=no&z=14&t=k&output=embed`} title="Kart til Umbukta-hytta (Google Maps)" />
          </div>
          <div style="padding:12px 16px; background:var(--flate); border-top:1px solid var(--kantlinje); display:flex; align-items:baseline; gap:12px; flex-wrap:wrap;">
            <b style="font-size:13.5px;" data-en="Umbukta cabin">Hytte i Umbukta</b>
            <a href={UMBUKTA.kart} target="_blank" rel="noopener noreferrer" class="btn-link" style="font-size:14px;">
              <span data-en="Open in Google Maps ↗">Åpne i Google Maps ↗</span>
            </a>
            <span class="muted" style="font-size:13px;">
              GPS: {UMBUKTA.lat}°N, {UMBUKTA.lon}°Ø
            </span>
          </div>
        </div>
        <!-- Naustet med båten (eget satellittkart) -->
        <div style="border-radius:4px; overflow:hidden; display:flex; flex-direction:column;">
          <div style="height:320px;">
            <MapEmbed src={`https://www.google.com/maps?q=${UMBUKTA.naustLat},${UMBUKTA.naustLon}&hl=no&z=16&t=k&output=embed`} title="Kart til naustet med båt (Google Maps)" />
          </div>
          <div style="padding:12px 16px; background:var(--flate); border-top:1px solid var(--kantlinje); display:flex; align-items:baseline; gap:12px; flex-wrap:wrap;">
