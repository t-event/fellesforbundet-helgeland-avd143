---
import Layout from '../layouts/Layout.astro';
import { KONTAKT } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Om Fellesforbundet Helgeland avd. 143"
  description="Fellesforbundet Helgeland avd. 143 holder til i Mo i Rana. Les om avdelingen, kontaktinfo og hytteutleien."
>
  <div class="container section" style="max-width:860px; margin:0 auto;">
    <h1 class="h1" style="font-size:clamp(28px,4vw,44px); margin-bottom:18px;"
        data-en="About Fellesforbundet Helgeland, branch 143">
      Om Fellesforbundet Helgeland avd. 143
    </h1>

    <p class="lead" style="margin-bottom:32px;"
       data-en="Fellesforbundet Helgeland is a local branch (no. 143) of Fellesforbundet — Norway's largest LO union. We represent workers in industry, construction, transport, forestry and a range of other sectors in Helgeland.">
      Fellesforbundet Helgeland er en lokal avdeling (nr. 143) av Fellesforbundet — Norges største LO-forbund.
      Vi representerer arbeidstakere innen industri, bygg og anlegg, transport, skog og en rekke andre bransjer på Helgeland.
    </p>

    <div class="grid" style="grid-template-columns:1fr 1fr; gap:24px; margin-bottom:40px;">
      <div class="card card-pad">
        <h2 class="h3" style="margin-bottom:14px;" data-en="Contact info">Kontaktinfo</h2>
        <ul style="display:flex; flex-direction:column; gap:12px; font-size:15px; color:var(--tekst-dempet);">
          <li><b style="color:var(--tekst);" data-en="Address">Adresse</b><br />{KONTAKT.adresse}<br />{KONTAKT.postnummer} {KONTAKT.poststed}</li>
          <li><b style="color:var(--tekst);" data-en="Phone">Telefon</b><br /><a href={`tel:+47${KONTAKT.telefon}`} class="btn-link">{KONTAKT.telefonFormatert}</a></li>
          <li><b style="color:var(--tekst);" data-en="Email">E-post</b><br /><a href={`mailto:${KONTAKT.epost}`} class="btn-link">{KONTAKT.epost}</a></li>
          <li><b style="color:var(--tekst);" data-en="Opening hours">Åpningstider</b><br />{KONTAKT.apningstider}</li>
          <li>
            <b style="color:var(--tekst);" data-en="Org. no.">Org.nr.</b><br />
            <a href={KONTAKT.brreg} target="_blank" rel="noopener noreferrer" class="btn-link">{KONTAKT.orgnr}</a>
          </li>
        </ul>
      </div>
      <div class="card card-pad">
        <h2 class="h3" style="margin-bottom:14px;" data-en="Links">Lenker</h2>
        <ul style="display:flex; flex-direction:column; gap:12px; font-size:15px;">
          <li><a href={KONTAKT.fellesforbundetUrl} target="_blank" rel="noopener noreferrer" class="btn-link">Fellesforbundet.no — Avd. 143 ↗</a></li>
          <li><a href={KONTAKT.facebookUrl} target="_blank" rel="noopener noreferrer" class="btn-link">Facebook ↗</a></li>
          <li><a href={KONTAKT.brreg} target="_blank" rel="noopener noreferrer" class="btn-link">Brønnøysundregistrene ↗</a></li>
        </ul>
      </div>
    </div>

    <h2 class="h2" style="font-size:26px; margin-bottom:16px;" data-en="Cabin rentals">Hytteutleie</h2>
    <p style="font-size:16px; line-height:1.7; color:var(--tekst-dempet); margin-bottom:20px;"
       data-en="Fellesforbundet Helgeland, avd. 143, owns two cabins rented out to LO members:">
      Fellesforbundet Helgeland avd. 143 eier to hytter som leies ut til LO-medlemmer:
    </p>
    <ul style="display:flex; flex-direction:column; gap:12px; font-size:16px; color:var(--tekst-dempet); margin-bottom:32px;">
      <li>
        <strong style="color:var(--tekst);" data-en="Cabin in Umbukta (Rana)">Hytte i Umbukta (Rana)</strong><span data-en=" — LO members only. Up to 12 beds. Booked here on the website. "> — kun for LO-medlemmer.
        Inntil 12 sengeplasser. Bookes her på nettsiden. </span>
        <a href={`${base}/umbukta`} class="btn-link" style="font-size:14px;" data-en="→ See the cabin">→ Se hytta</a>
      </li>
      <li>
        <strong style="color:var(--tekst);" data-en="Cabin in Øvre Elsvatn (Hattfjelldal)">Hytte i Øvre Elsvatn (Hattfjelldal)</strong><span data-en=" — open to everyone. 6 beds. Booked via inatur.no. "> — åpen for alle.
        6 sengeplasser. Bookes via inatur.no. </span>
        <a href="https://www.inatur.no/hytte/670e2bd422a51709667760cd/hytte-i-ovre-elsvatn-hattfjelldal" target="_blank" rel="noopener noreferrer" class="btn-link" style="font-size:14px;" data-en="→ See on inatur ↗">→ Se på inatur ↗</a>
      </li>
    </ul>

    <a href={`${base}/`} class="btn btn-secondary" data-en="← Back to home">← Tilbake til forsiden</a>
  </div>
</Layout>
