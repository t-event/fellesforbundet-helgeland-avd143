---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Cookies — Fellesforbundet Helgeland Hytteutleie"
  description="Informasjon om bruk av informasjonskapsler (cookies) på hytteutleie-nettsiden til Fellesforbundet Helgeland."
>
  <div class="container section" style="max-width:720px; margin:0 auto;">
    <h1 class="h1" style="font-size:clamp(26px,3.6vw,38px); margin-bottom:32px;" data-en="Cookies">
      Informasjonskapsler (cookies)
    </h1>
    <div style="display:flex; flex-direction:column; gap:24px; font-size:16px; line-height:1.75; color:var(--tekst-dempet);">
      <p data-en="This website uses very few cookies — and no tracking or advertising.">
        Denne nettsiden bruker svært få informasjonskapsler — og ingen sporing eller reklame.
      </p>
      <div class="card card-pad">
        <table style="width:100%; border-collapse:collapse; font-size:14.5px;">
          <thead>
            <tr style="border-bottom:2px solid var(--kantlinje);">
              <th style="text-align:left; padding:10px 8px; font-weight:700; color:var(--tekst);" data-en="Name">Navn</th>
              <th style="text-align:left; padding:10px 8px; font-weight:700; color:var(--tekst);" data-en="Purpose">Formål</th>
              <th style="text-align:left; padding:10px 8px; font-weight:700; color:var(--tekst);" data-en="Duration">Varighet</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--kantlinje);">
              <td style="padding:12px 8px;"><code>lang</code></td>
              <td style="padding:12px 8px;" data-en="Stores your chosen language (NO/EN)">Lagrer valgt språk (NO/EN)</td>
              <td style="padding:12px 8px;" data-en="Until you delete it / the browser closes">Inntil du sletter den / nettleseren lukkes</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p data-en="No third-party analytics, Facebook Pixel, Google Analytics or similar. The site is static and does not collect data unless you actively fill in a form.">
        Ingen tredjeparts analyse, Facebook Pixel, Google Analytics eller lignende. Siden er statisk og samler
        ikke inn data uten at du aktivt fyller ut et skjema.
      </p>
      <p>
        <span data-en="You can delete cookies in your browser settings at any time. Read more in our ">Du kan slette cookies i nettleserinnstillingene dine når som helst.
        Les mer i vår </span><a href={`${base}/personvern`} class="btn-link" data-en="privacy policy">personvernerklæring</a>.
      </p>
    </div>
  </div>
</Layout>
