---
import Layout from '../layouts/Layout.astro';
import CircleMotif from '../components/CircleMotif.astro';
import Icon from '../components/Icon.astro';
import { STYRE, ANSATTE, KONTROLLKOMITE, STUDIEUTVALG, UNGDOMSUTVALG, KONTAKT } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const initialer = (navn: string) =>
  navn.split(/\s+/).map(d => d[0]).join('').slice(0, 2).toUpperCase();

const verktoy = [
  { ikon: 'book-open',      tittel: 'Håndbok for tillitsvalgte', tittel_en: 'Shop steward handbook', body: 'Rettigheter, plikter og praktiske råd i tillitsvervet.', body_en: 'Rights, duties and practical advice in the role.', href: 'https://www.fellesforbundet.no/for-tillitsvalgte/', ekstern: true },
  { ikon: 'graduation-cap', tittel: 'Grunnopplæring',            tittel_en: 'Basic training',        body: 'Kurs og arrangementer for tillitsvalgte hos Fellesforbundet.', body_en: 'Courses and events for shop stewards at Fellesforbundet.', href: 'https://www.fellesforbundet.no/aktuelt/kurs-og-arrangementer/', ekstern: true },
  { ikon: 'phone',          tittel: 'Rådgivningstelefon',        tittel_en: 'Advisory line',         body: `Ring avdelingen på ${KONTAKT.telefonFormatert} når du står i en sak.`, body_en: `Call the branch on ${KONTAKT.telefonFormatert} when you face a case.`, href: `tel:+47${KONTAKT.telefon}`, ekstern: false },
];
---

<Layout
  title="Tillitsvalgte — Fellesforbundet Helgeland avd. 143"
  description="Tillitsvalgte i Fellesforbundet avd. 143. Ledelse, verktøy for tillitsvalgte og veien til å bli tillitsvalgt på din arbeidsplass."
>

  <!-- HERO -->
  <div class="hero-dark">
    <CircleMotif variant="mork-oransje" class="hero-motif" />
    <div class="container section">
      <div class="hero-grid" style="align-items:center;">
        <div>
          <span class="hero-pill" data-en="Shop stewards">Tillitsvalgte</span>
          <h1 class="h1" style="margin-top:18px;" data-en="The shop stewards — closest to you">Tillitsvalgte — nærmest deg</h1>
          <p class="lead" style="max-width:52ch; margin-top:20px;"
             data-en="The shop stewards are your representatives at the workplace and in the branch. They negotiate, raise cases and look after your rights.">
            Tillitsvalgte er dine representanter på arbeidsplassen og i avdelingen. De forhandler,
            tar opp saker og passer på rettighetene dine.
          </p>
        </div>
        <div class="hero-img">
          <img src={`${base}/images/hovedside/medlemsmote.jpg`} alt="Medlemmer samlet på møte i avdelingen" width="1500" height="843" loading="eager" style="width:100%; height:100%; object-fit:cover;" />
        </div>
      </div>
    </div>
  </div>

  <div class="container">

    <!-- ANSATTE -->
    <div class="section">
      <span class="eyebrow" data-en="Staff">Ansatte</span>
      <h2 class="h2" style="margin:6px 0 10px;" data-en="The branch's staff">Avdelingens ansatte</h2>
      <p class="muted" style="font-size:16px; max-width:62ch; margin-bottom:18px;"
         data-en="The branch's organisers and office staff are spread across Helgeland and are here for members and shop stewards.">
        Avdelingens organisasjonsarbeidere og kontoransatte er spredt over Helgeland og er her for medlemmer og tillitsvalgte.
      </p>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px;">
        {ANSATTE.map(a => (
          <div class="person">
            <span class="person-avatar" aria-hidden="true">{initialer(a.navn)}</span>
            <div>
              <b style="display:block; font-size:15px;">{a.navn}</b>
              <span class="muted" style="font-size:13px;" data-en={a.rolle_en}>{a.rolle}</span>
              <span class="muted" style="display:block; font-size:12.5px;">{a.sted} · {a.stilling}</span>
            </div>
          </div>
        ))}
      </div>
      <p class="muted" style="font-size:13.5px; margin-top:14px;" data-en="Reach the staff through the branch office: ">
        Du når de ansatte gjennom avdelingskontoret: <a href={`tel:+47${KONTAKT.telefon}`} class="btn-link" style="font-size:13.5px;">{KONTAKT.telefonFormatert}</a>
      </p>
    </div>

    <!-- STYRET -->
    <div class="section">
      <span class="eyebrow" data-en="The board">Styret</span>
      <h2 class="h2" style="margin:6px 0 10px;" data-en="The branch board">Avdelingens styre</h2>
      <p class="muted" style="font-size:16px; max-width:62ch; margin-bottom:10px;"
         data-en="The board is elected by the members and leads the branch's work.">
        Styret velges av medlemmene og leder avdelingens arbeid.
      </p>
      <p style="font-size:15px; margin-bottom:18px;" data-en="Branch office: ">
        Avdelingskontoret: <a href={`tel:+47${KONTAKT.telefon}`} class="btn-link" style="font-size:15px;">{KONTAKT.telefonFormatert}</a>
        <span class="muted"> · </span>
        <a href={`mailto:${KONTAKT.epost}`} class="btn-link" style="font-size:15px;">{KONTAKT.epost}</a>
      </p>
      <!-- Leder -->
      <div class="person" style="max-width:400px; margin-bottom:22px;">
        <span class="person-avatar" aria-hidden="true">{initialer(STYRE[0].navn)}</span>
        <div>
          <b style="display:block; font-size:15.5px;">{STYRE[0].navn}</b>
          <span class="muted" style="font-size:13.5px;" data-en={STYRE[0].rolle_en}>{STYRE[0].rolle}</span>
          <span class="muted" style="display:block; font-size:12.5px;">{STYRE[0].klubb}</span>
          <div style="font-size:13.5px; margin-top:6px;">
            <a href={`tel:+47${STYRE[0].tlf}`} class="btn-link" style="font-size:13.5px;">{STYRE[0].tlfFormatert}</a>
            <span class="muted"> · </span>
            <a href={`mailto:${STYRE[0].epost}`} class="btn-link" style="font-size:13.5px;">{STYRE[0].epost}</a>
          </div>
        </div>
      </div>

      <!-- Ledelse (nestleder, sekretær, ungdomsledelse) + øvrige styremedlemmer -->
      <h3 class="h3" style="font-size:16px; margin:8px 0 14px;" data-en="Board members">Styret for øvrig</h3>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:14px;">
        {STYRE.slice(1).map(p => (
          <div class="person">
            <span class="person-avatar" aria-hidden="true">{initialer(p.navn)}</span>
            <div>
              <b style="display:block; font-size:15px;">{p.navn}</b>
              <span class="muted" style="font-size:13px;" data-en={p.rolle_en}>{p.rolle}</span>
              <span class="muted" style="display:block; font-size:12.5px;">{p.klubb}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Ungdomsutvalg -->
      <h3 class="h3" style="font-size:16px; margin:32px 0 14px;" data-en="Youth committee">Ungdomsutvalg</h3>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:14px;">
        {UNGDOMSUTVALG.map(p => (
          <div class="person">
            <span class="person-avatar" aria-hidden="true">{initialer(p.navn)}</span>
            <div>
              <b style="display:block; font-size:15px;">{p.navn}</b>
              <span class="muted" style="font-size:13px;" data-en={p.rolle_en}>{p.rolle}</span>
              {'merknad' in p && (
                <span class="muted" style="display:block; font-size:12.5px;" data-en={(p as any).merknad_en}>{(p as any).merknad}</span>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Kontrollkomité + studieutvalg -->
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:24px; margin-top:32px;">
        <div>
          <h3 class="h3" style="font-size:16px; margin:0 0 12px;" data-en="Control committee">Kontrollkomité</h3>
          <ul class="muted" style="font-size:14px; line-height:1.7; list-style:none; padding:0; margin:0;">
            {KONTROLLKOMITE.map(k => (
              <li>
                <b style="color:var(--tekst);">{k.navn}</b>
                <span data-en=" (deputy: "> (vara: </span>{k.vara})
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="h3" style="font-size:16px; margin:0 0 12px;" data-en="Study committee">Studieutvalg</h3>
          <ul class="muted" style="font-size:14px; line-height:1.7; list-style:none; padding:0; margin:0;">
            {STUDIEUTVALG.map(s => (
              <li><b style="color:var(--tekst);">{s.navn}</b> · {s.sted}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- VERKTØY -->
    <div class="section" style="padding-top:0;">
      <span class="eyebrow" data-en="Tools for shop stewards">Verktøy for tillitsvalgte</span>
      <h2 class="h2" style="margin:6px 0 32px;" data-en="Support in the role">Støtte i vervet</h2>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px;">
        {verktoy.map(v => (
          <a
            href={v.href}
            class="benefit benefit-link"
            target={v.ekstern ? '_blank' : undefined}
            rel={v.ekstern ? 'noopener noreferrer' : undefined}
          >
            <span class="benefit-ic" aria-hidden="true"><Icon name={v.ikon} size={22} /></span>
            <h3 class="h3" style="font-size:17px; margin-bottom:6px; display:flex; align-items:center; gap:6px;" data-en={v.tittel_en}>
              {v.tittel}<span class="benefit-pil" aria-hidden="true">{v.ekstern ? '↗' : '→'}</span>
            </h3>
            <p class="muted" style="font-size:14px; line-height:1.6;" data-en={v.body_en}>{v.body}</p>
          </a>
        ))}
      </div>
    </div>

    <!-- BLI TILLITSVALGT -->
    <div class="section" style="padding-top:0;">
      <div class="cta-band">
        <div>
          <h2 class="h2" style="color:#fff; font-size:clamp(22px,2.8vw,32px); max-width:16ch;" data-en="Want to become a shop steward?">Vil du bli tillitsvalgt?</h2>
          <p style="color:#dcdce8; font-size:16px; margin-top:12px; max-width:48ch; line-height:1.6;"
             data-en="Shop stewards make a difference at the workplace — and get training and support from the branch. Get in touch to hear more.">
            Tillitsvalgte gjør en forskjell på arbeidsplassen — og får opplæring og støtte fra
            avdelingen. Ta kontakt for å høre mer.
          </p>
        </div>
        <a href={`${base}/kontakt`} class="btn btn-primary" data-en="Get in touch →">Ta kontakt →</a>
      </div>
    </div>

  </div>
</Layout>
