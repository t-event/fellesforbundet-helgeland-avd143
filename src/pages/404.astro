---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="404 — Side ikke funnet | Fellesforbundet Helgeland Hytteutleie"
  description="Siden du leter etter finnes ikke. Gå tilbake til forsiden for hytteutleie hos Fellesforbundet Helgeland."
>
  <div style="min-height:60vh; display:flex; align-items:center; justify-content:center; background:var(--flate);">
    <div style="text-align:center; padding:clamp(32px,6vw,64px) 24px;">
      <div style="font-size:100px; font-weight:900; color:var(--rod); line-height:1; margin-bottom:16px;">404</div>
      <h1 class="h2" style="margin-bottom:12px;">Side ikke funnet</h1>
      <p class="muted" style="font-size:16px; margin-bottom:32px; max-width:40ch; margin-left:auto; margin-right:auto;">
        Siden du leter etter eksisterer ikke eller har blitt flyttet.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
        <a href={`${base}/`} class="btn btn-primary">← Til forsiden</a>
        <a href={`${base}/umbukta`} class="btn btn-secondary">Se Umbukta-hytta</a>
        <a href={`${base}/hjelp`} class="btn btn-secondary">Hjelpesenter</a>
      </div>
    </div>
  </div>
</Layout>
