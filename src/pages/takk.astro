---
import Layout from '../layouts/Layout.astro';
import { KONTONUMMER } from '../config.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Takk for forespørselen — Fellesforbundet Helgeland Hytteutleie"
  description="Vi har mottatt din bookingforespørsel for Hytta i Umbukta. Her finner du betalingsinstruksen."
>
  <div style="background:var(--flate); min-height:70vh;">
    <div class="container section">

      <div class="receipt">
        <span class="receipt-check">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12.5l4.5 4.5L19 7.5"/>
          </svg>
        </span>
        <h1 class="h1" style="font-size:clamp(28px,4vw,40px); margin-bottom:12px;" data-i18n="takk_title">
          Takk for din forespørsel!
        </h1>
        <p class="lead" style="margin:0 auto;" id="takk-lead-tekst"
           data-en="We have received your request for the <strong>Umbukta cabin</strong>. The office will review it and contact you by email.">
          Vi har mottatt forespørselen din om <strong>Hytte i Umbukta</strong>.
          Avdelingen ser over og tar kontakt på e-post.
        </p>
      </div>

      <!-- Betalingsinfo-kortet (fylles inn fra URL-params) -->
      <div class="card card-pad" style="max-width:680px; margin:36px auto 22px; padding:30px;" id="takk-detaljer">
        <h2 class="h2" style="font-size:20px; margin-bottom:20px;" data-i18n="takk_payment_title">
          Betalingsinstruks
        </h2>
        <div class="kv-row">
          <span class="k" data-i18n="takk_konto">Kontonummer</span>
          <span class="v">{KONTONUMMER}</span>
        </div>
        <div class="kv-row" id="takk-row-datoer" style="display:none;">
          <span class="k" data-en="Rental period">Leieperiode</span>
          <span class="v" id="takk-datoer">–</span>
        </div>
        <div class="kv-row" id="takk-row-dager" style="display:none;">
          <span class="k" data-en="Nights">Antall døgn</span>
          <span class="v" id="takk-dager">–</span>
        </div>
        <div class="kv-row" id="takk-row-ref" style="display:none;">
          <span class="k" data-i18n="takk_ref">Betalingsreferanse</span>
          <span class="v" id="takk-ref">–</span>
        </div>
        <div class="kv-row" id="takk-row-sum" style="display:none;">
          <span class="k" data-i18n="takk_belop">Beløp</span>
          <span class="v big" id="takk-sum">–</span>
        </div>
      </div>

      <!-- Viktig varsel -->
      <div class="alert alert-warn" style="max-width:680px; margin:0 auto 30px;">
        <span class="ic">!</span>
        <p style="font-size:14.5px; line-height:1.6;" data-i18n="takk_warning">
          <strong>Datoen er ikke reservert før avdelingen bekrefter.</strong>
          Du får dørkoden på SMS/e-post fra avdelingen når betalingen er registrert.
        </p>
      </div>

      <div style="text-align:center; margin-bottom:16px;">
        <div class="alert alert-green" style="max-width:680px; margin:0 auto 22px; text-align:left;">
          <span class="ic">✓</span>
          <p style="font-size:14.5px; line-height:1.6;"
             data-en="Your request has been registered. Note down the payment reference above — you'll use it when paying. The office will confirm the booking by email.">
            Forespørselen din er registrert. Ta vare på betalingsreferansen over — den bruker du ved betaling.
            Avdelingen bekrefter bookingen på e-post.
          </p>
        </div>
      </div>

      <div class="takk-actions" style="text-align:center; display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <button type="button" id="takk-print" class="btn btn-secondary" data-en="Print / save as PDF">Skriv ut / lagre som PDF</button>
        <button type="button" id="takk-ics" class="btn btn-secondary" style="display:none;" data-en="Add to calendar (.ics)">Legg i kalender (.ics)</button>
        <a href={`${base}/`} class="btn btn-ghost-dark" data-i18n="takk_back">← Tilbake til forsiden</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .btn-ghost-dark { background: transparent; color: var(--tekst); border: 1.5px solid var(--kantlinje); }
  .btn-ghost-dark:hover { border-color: var(--rod); color: var(--rod); }

  /* Print: rendyrk betalingsinstruksen (skjul chrome/knapper, hvit bakgrunn) */
  @media print {
    .site-header, .site-footer, #cookie-banner, .takk-actions, .receipt-check, .btn { display: none !important; }
    :global(body) { background: #fff !important; }
    .receipt, .card, .alert { box-shadow: none !important; }
    .card, .alert { border: 1px solid #ccc !important; break-inside: avoid; }
    a[href]::after { content: ""; }
  }
</style>

<script define:vars={{ KONTONUMMER }}>
// Les detaljer fra URL-params (satt av BookingForm.astro)
const p = new URLSearchParams(window.location.search);
const fra   = p.get('fra')   ?? '';
const til   = p.get('til')   ?? '';
const dager = p.get('dager') ?? '';
const sum   = p.get('sum')   ?? '';
const ref   = p.get('ref')   ?? '';
const navn  = p.get('navn')  ?? '';

function vis(id, tekst) {
  const row = document.getElementById(`takk-row-${id}`);
  const val = document.getElementById(`takk-${id}`);
  if (row && val && tekst) {
    val.textContent = tekst;
    row.style.display = '';
  }
}

const erEn = () => localStorage.getItem('lang') === 'en';

function fyll() {
  const loc = erEn() ? 'en-GB' : 'nb-NO';
  if (fra && til) {
    const fmtFra = new Date(fra).toLocaleDateString(loc, { day:'numeric', month:'long', year:'numeric' });
    const fmtTil = new Date(til).toLocaleDateString(loc, { day:'numeric', month:'long', year:'numeric' });
    vis('datoer', `${fmtFra} – ${fmtTil}`);
  }
  if (dager) vis('dager', erEn() ? `${dager} ${dager === '1' ? 'night' : 'nights'}` : `${dager} døgn`);
  if (ref)   vis('ref',   ref);
  if (sum)   vis('sum',   erEn() ? `NOK ${parseInt(sum).toLocaleString('en-US')}` : `${parseInt(sum).toLocaleString('nb-NO')} kr`);

  if (fra && til && navn) {
    const fmtFra = new Date(fra).toLocaleDateString(loc, { day:'numeric', month:'long' });
    const fmtTil = new Date(til).toLocaleDateString(loc, { day:'numeric', month:'long', year:'numeric' });
    const lead = document.getElementById('takk-lead-tekst');
    if (lead) {
      // Bygg med DOM-noder — navn fra URL settes som tekstnode og kan derfor
      // aldri tolkes som HTML/skript (hindrer DOM-basert XSS).
      const strong = (t) => { const s = document.createElement('strong'); s.textContent = t; return s; };
      lead.replaceChildren(
        document.createTextNode(erEn() ? 'We have received your request for the ' : 'Vi har mottatt forespørselen din om '),
        strong(erEn() ? 'Umbukta cabin' : 'Hytte i Umbukta'),
        document.createTextNode(erEn() ? ' for ' : ' for '),
        strong(`${fmtFra}–${fmtTil}`),
        document.createTextNode(`, ${navn}`),
        document.createTextNode(erEn() ? '. The office will review it and contact you by email.' : '. Avdelingen ser over og tar kontakt på e-post.'),
      );
    }
  }
}
fyll();
document.querySelectorAll('.lang button').forEach(b =>
  b.addEventListener('click', () => setTimeout(fyll, 0)));

// Skriv ut / lagre som PDF
document.getElementById('takk-print')?.addEventListener('click', () => window.print());

// Legg i kalender (.ics) — kun når leieperioden er kjent.
// URL-params kan manipuleres i en delt lenke, så datoer valideres strengt og
// tekstfelt renses (CR/LF fjernes, ICS-spesialtegn escapes) før de legges i fila.
const isIsoDato = (s) => /^\d{4}-\d{2}-\d{2}$/.test(s);
const icsTekst = (s) => String(s).replace(/[\r\n]+/g, ' ').replace(/([\\;,])/g, '\\$1');
const icsBtn = document.getElementById('takk-ics');
if (icsBtn && isIsoDato(fra) && isIsoDato(til)) {
  icsBtn.style.display = '';
  icsBtn.addEventListener('click', () => {
    const dt = (s) => s.replace(/-/g, '');
    const stamp = new Date().toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    const uid = (ref || 'umbukta-' + dt(fra)).replace(/[^A-Za-z0-9-]/g, '') + '@ffh143.no';
    const desc = icsTekst(`Betalingsreferanse: ${ref || '-'}. Kontonr: ${KONTONUMMER}.` + (sum ? ` Belop: ${sum} kr.` : ''));
    const ics = [
      'BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//FFH avd 143//Hytte Umbukta//NO', 'CALSCALE:GREGORIAN',
      'BEGIN:VEVENT', `UID:${uid}`, `DTSTAMP:${stamp}`,
      `DTSTART;VALUE=DATE:${dt(fra)}`, `DTEND;VALUE=DATE:${dt(til)}`,
      'SUMMARY:Hytte i Umbukta — Fellesforbundet Helgeland',
      `DESCRIPTION:${desc}`, 'LOCATION:Umbukta', 'END:VEVENT', 'END:VCALENDAR',
    ].join('\r\n');
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `umbukta-${dt(fra)}.ics`;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(a.href);
  });
}
</script>
